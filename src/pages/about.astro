---
import BaseLayout from "../layouts/BaseLayout.astro";
import BackLink from "../components/BackLink.astro";
import { getLangFromUrl } from "../i18n/getLang";
import { getTranslations } from "../i18n/index";

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
---

<BaseLayout>
    <article class="max-w-3xl mx-auto">
        <BackLink href="/" label={t.about.back} />

        <!-- HERO -->

        <section class="mb-20 flex flex-col md:flex-row items-center gap-10">

            <img
                src="/og-image.png"
                alt="Miguel Ángel Moza Barquilla"
                class="w-80 h-80 rounded-full object-cover border border-gray-200 dark:border-gray-800 shadow-md ring-2 ring-blue-500/20"
            />

            <div>
                <h1 class="text-3xl md:text-4xl font-bold mb-4">{t.about.hero.title}</h1>

                <p class="text-gray-600 dark:text-gray-400 mb-4">
                    {t.about.hero.intro}
                </p>

                <p class="text-gray-600 dark:text-gray-400">
                    {t.about.hero.path}
                </p>
            </div>
        </section>

        <!-- MY JOURNEY -->

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">{t.about.journey.title}</h2>

            {t.about.journey.paragraphs.map((paragraph) => (
              <p class="text-gray-600 dark:text-gray-400 mb-4">
                {paragraph}
              </p>
            ))}
        </section>

        <!-- DISCOVERING PROGRAMMING -->

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">{t.about.discovering.title}</h2>

            {t.about.discovering.paragraphs.map((paragraph) => (
              <p class="text-gray-600 dark:text-gray-400 mb-4">
                {paragraph}
              </p>
            ))}
        </section>

        <!-- BECOMING A DEVELOPER -->

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">{t.about.becoming.title}</h2>

            {t.about.becoming.paragraphs.map((paragraph) => (
              <p class="text-gray-600 dark:text-gray-400 mb-4">
                {paragraph}
              </p>
            ))}
        </section>

        <!-- OUTSIDE TECH -->

        <section class="mb-16">
        <h2 class="text-xl font-semibold mb-6">{t.about.outsideTech.title}</h2>

        <p class="text-gray-600 dark:text-gray-400 mb-6">
            {t.about.outsideTech.intro}
        </p>

        <ul class="space-y-4">
            {t.about.outsideTech.activities.map((activity) => (
            <li class="flex flex-col">
                <span class="font-medium text-gray-900 dark:text-gray-100">
                {activity.name}
                </span>

                <span class="text-sm text-gray-600 dark:text-gray-400 ml-6">
                {activity.description}
                </span>
            </li>
            ))}
        </ul>
        </section>

        <!-- MINDSET -->

        <section>
            <h2 class="text-xl font-semibold mb-6">
                {t.about.mindset.title}
            </h2>

            {t.about.mindset.paragraphs.map((paragraph) => (
              <p class="text-gray-600 dark:text-gray-400 mb-4">
                {paragraph}
              </p>
            ))}
        </section>
    </article>
</BaseLayout>
