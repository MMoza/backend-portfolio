---
import BaseLayout from "../layouts/BaseLayout.astro";
import TechStackCarousel from "../components/TechStackCarousel.astro";
import { getLangFromUrl } from "../i18n/getLang";
import { getTranslations } from "../i18n";


const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
---

<BaseLayout>
  <section
    class="relative max-w-3xl mx-auto py-24 text-center animate-fade-in overflow-hidden rounded-2xl"
  >
    <!-- Foreground content -->
    <div class="relative z-10">
      <div class="neon-wrapper mb-16 -rotate-6">
        <p class="neon-text">
          {t.home.hero.greeting}<span class="neon-exclamation">!</span>
        </p>

        <p class="neon-glow">
          {t.home.hero.greeting}<span class="neon-exclamation">!</span>
        </p>
      </div>

      <h1
        class="text-4xl md:text-5xl font-bold leading-tight mb-6 opacity-0 animate-slide-up"
      >
        {t.home.hero.titleBefore}
        <span class="text-blue-600">{t.home.hero.titleAccent}</span>
        {t.home.hero.titleAfter}
      </h1>

      <p
        class="text-lg text-gray-600 dark:text-gray-400 mb-10 opacity-0 animate-slide-up-delay"
      >
        {t.home.hero.description}
      </p>

      <div class="flex justify-center gap-4 opacity-0 animate-slide-up-delay-2">
        <a
          href="/projects"
          class="px-6 py-3 rounded-lg bg-gray-900 text-white dark:bg-white dark:text-black font-medium hover:opacity-90 transition"
        >
          {t.home.cta.projects}
        </a>

        <a
          href="/contact"
          class="px-6 py-3 rounded-lg border border-gray-300 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-800 transition"
        >
          {t.home.cta.contact}
        </a>
      </div>

      <TechStackCarousel />
    </div>
  </section>

  <style>
    @keyframes fadeIn {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(16px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-fade-in {
      animation: fadeIn 0.8s ease forwards;
    }

    .animate-fade-in-delay {
      animation: fadeIn 0.8s ease forwards;
      animation-delay: 0.1s;
    }

    .animate-slide-up {
      animation: slideUp 0.7s ease forwards;
      animation-delay: 0.15s;
    }

    .animate-slide-up-delay {
      animation: slideUp 0.7s ease forwards;
      animation-delay: 0.3s;
    }

    .animate-slide-up-delay-2 {
      animation: slideUp 0.7s ease forwards;
      animation-delay: 0.45s;
    }

    .code-scroll {
      animation: codeDrift 40s linear infinite;
    }

    @keyframes codeDrift {
      0% {
        transform: translateX(0);
      }
      50% {
        transform: translateX(-20px);
      }
      100% {
        transform: translateX(0);
      }
    }

    .neon-wrapper {
      position: relative;
      display: inline-block;
    }

    .neon-text {
      position: relative;
      font-size: 1.875rem;
      letter-spacing: 0.05em;
      color: #facc15;

      text-shadow:
        0 0 1px currentColor,
        0 0 2px currentColor,
        0 0 3px currentColor;

      animation:
        neonFloat 6s ease-in-out infinite,
        neonFlicker 5s infinite;
    }

    .neon-glow {
      position: absolute;
      inset: 0;

      font-size: 1.875rem;
      letter-spacing: 0.05em;

      color: #facc15;

      filter: blur(10px);
      opacity: 0.7;

      animation: neonGlowPulse 3s ease-in-out infinite;
    }

    html:not(.dark) .neon-text {
      color: #84cc16;
    }

    html:not(.dark) .neon-glow {
      color: #84cc16;
    }

    .neon-text,
    .neon-glow {
      transition: color 0.6s ease;
    }

    @keyframes neonGlowPulse {
      0%,
      100% {
        opacity: 0.65;
        filter: blur(10px);
      }

      50% {
        opacity: 1;
        filter: blur(14px);
      }
    }

    @keyframes neonFlicker {
      0%,
      18%,
      22%,
      25%,
      53%,
      57%,
      100% {
        opacity: 1;
      }

      20%,
      24%,
      55% {
        opacity: 0.4;
      }
    }

    .neon-exclamation {
      animation: neonFlickerStrong 2.5s infinite;
      font-size: 36px
    }

    @keyframes neonFlickerStrong {

      0%, 19%, 23%, 60%, 100% {
        opacity: 1;
      }

      20%, 22% {
        opacity: 0.1;
      }

      61% {
        opacity: 0.3;
      }

    }
  </style>
</BaseLayout>
