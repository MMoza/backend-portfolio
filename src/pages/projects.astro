---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import BackLink from "../components/BackLink.astro";

const projects = [
  {
    slug: "architecture-comparison",
    date: "2026",
    title: "Architecture Comparison Lab",
    tech: ["PHP", "Laravel", "Architecture"],
    github: "https://github.com/MMoza/reservations",
    description:
      "Experiment comparing multiple backend architectures and how they evolve as domain complexity increases."
  },
  {
    slug: "api-benchmark",
    date: "2026",
    title: "API Architecture Benchmark",
    tech: ["PHP", "Symfony", "Laravel", "REST", "API"],
    github: "https://github.com/MMoza/api-benchmark",
    description:
      "Comparison of API implementations using native PHP, Symfony and Laravel analysing complexity and maintainability."
  },
  {
    slug: "patterns-playground",
    date: "2026",
    title: "Design Patterns Playground",
    tech: ["PHP", "Design Patterns"],
    github: "https://github.com/MMoza/design-patterns",
    description:
      "Practical exploration of backend design patterns applied to real business rules and domain modelling."
  },
  {
    slug: "randomuser-technical-test",
    date: "2023",
    title: "First Technical Test",
    tech: ["PHP", "Ajax", "JQuery"],
    github: "https://github.com/MMoza/pruebaAjax",
    description:
      "This project represents the technical test I completed during the selection process for my first professional role as a web developer."
  }
];
---

<BaseLayout>

<section class="max-w-5xl mx-auto">

<BackLink href="/" label="Back to home" />

  <header class="mb-16">

    <h1 class="text-3xl md:text-4xl font-bold mb-4">
      Projects
    </h1>

    <p class="text-gray-600 dark:text-gray-400 max-w-2xl">
      Experiments and projects focused on backend architecture, system
      evolution and software design decisions.
    </p>

  </header>


  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

    {projects.map((project) => (

        <ProjectCard project={project} />

    ))}

  </div>

</section>

</BaseLayout>