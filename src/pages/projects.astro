---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import BackLink from "../components/BackLink.astro";

import { getLangFromUrl } from "../i18n/getLang";
import { getTranslations } from "../i18n";

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);

const backendProjects = [
  {
    slug: "architecture-comparison",
    date: "2026",
    tech: ["PHP", "Laravel", "Architecture"],
    github: "https://github.com/MMoza/reservations",
    status: "finished",
    image: "/arhitecture-lab.png"
  },
  {
    slug: "api-benchmark",
    date: "2026",
    tech: ["PHP", "Symfony", "Laravel", "REST", "API"],
    github: "https://github.com/MMoza/api-benchmark",
    status: "in_progress",
    image: "/api-benchmark.png"
  },
  {
    slug: "patterns-playground",
    date: "2026",
    tech: ["PHP", "Design Patterns"],
    github: "https://github.com/MMoza/design-patterns",
    status: "upcoming",
    image: "/patterns.png"
  },
  {
    slug: "randomuser-technical-test",
    date: "2023",
    tech: ["PHP", "Ajax", "JQuery"],
    github: "https://github.com/MMoza/pruebaAjax",
    status: "finished",
    image: "/random-user.png"
  },
  {
    slug: "laravel-ddd",
    date: "2025",
    tech: ["PHP", "Laravel", "DDD", "Composer"],
    github: "https://github.com/MMoza/laravel-ddd",
    status: "finished",
    image: "/laravel-ddd.png"
  },
  {
    slug: "design-antipatterns",
    date: "2026",
    tech: ["PHP", "Software Design", "Best Practices"],
    github: "https://github.com/MMoza/design-antipatterns",
    status: "in_progress",
    image: "/design-antipatterns.png"
  }
];

const webProjects = [
  {
    slug: "milon-ai",
    date: "2025",
    tech: ["Astro", "Prompt API", "Gemini Nano", "AI"],
    github: "https://github.com/MMoza/milon-ai",
    status: "finished",
    image: "/milon-ai.png"
  },
  {
    slug: "mmodula",
    date: "2025",
    tech: ["Modular Architecture", "Verifactu", "Blockchain", "HR"],
    github: "https://github.com/MMoza/mmodula",
    status: "in_progress",
    image: "/mmodula.png"
  },
  {
    slug: "social-drum",
    date: "2026",
    tech: ["React", "Laravel", "MIDI", "Web Audio API"],
    github: "https://github.com/MMoza/social-drum",
    status: "in_progress",
    image: "/social-drum.png"
  }
];
---

<BaseLayout>

<section class="max-w-5xl mx-auto">

<BackLink href="/" label={t.projects.back} />

  <header class="mb-16">

    <h1 class="text-3xl md:text-4xl font-bold mb-4">
      {t.projects.title}
    </h1>

    <p class="text-gray-600 dark:text-gray-400 max-w-2xl">
      {t.projects.description}
    </p>

  </header>


<style>
  .scroll-section::-webkit-scrollbar {
    height: 6px;
  }
  .scroll-section::-webkit-scrollbar-track {
    background: rgba(156, 163, 175, 0.2);
    border-radius: 3px;
  }
  .scroll-section::-webkit-scrollbar-thumb {
    background: rgba(59, 130, 246, 0.5);
    border-radius: 3px;
  }
  .scroll-section::-webkit-scrollbar-thumb:hover {
    background: rgba(59, 130, 246, 0.7);
  }
</style>

<section class="mb-16">
  <h2 class="text-2xl font-bold mb-6">{t.projects.sections.backend.title}</h2>
  <p class="text-gray-600 dark:text-gray-400 mb-6">{t.projects.sections.backend.description}</p>
  <div class="scroll-section flex gap-6 overflow-x-auto pb-4 snap-x snap-mandatory">
    {backendProjects.map((project) => {
      const translation = t.projects.items[project.slug];
      return (
        <div class="flex-shrink-0 w-80 snap-start">
          <ProjectCard
            project={{
              ...project,
              title: translation.title,
              description: translation.description
            }}
          />
        </div>
      );
    })}
  </div>
</section>

<section class="mb-16">
  <h2 class="text-2xl font-bold mb-6">{t.projects.sections.web.title}</h2>
  <p class="text-gray-600 dark:text-gray-400 mb-6">{t.projects.sections.web.description}</p>
  <div class="scroll-section flex gap-6 overflow-x-auto pb-4 snap-x snap-mandatory">
    {webProjects.map((project) => {
      const translation = t.projects.items[project.slug];
      return (
        <div class="flex-shrink-0 w-80 snap-start">
          <ProjectCard
            project={{
              ...project,
              title: translation.title,
              description: translation.description
            }}
          />
        </div>
      );
    })}
  </div>
</section>

</section>

</BaseLayout>