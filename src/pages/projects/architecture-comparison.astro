---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BackLink from "../../components/BackLink.astro";

import { getLangFromUrl } from "../../i18n/getLang";
import { getTranslations } from "../../i18n";

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
---

<BaseLayout>
    <article class="max-w-3xl mx-auto">
        <BackLink href="/projects" label={t.architectureComparison.back} />

        <header class="mb-14">
            <h1 class="text-3xl md:text-4xl font-bold mb-4">
                {t.architectureComparison.header.title}
            </h1>

            <p class="text-lg text-gray-600 dark:text-gray-400">
                {t.architectureComparison.header.description}
            </p>
        </header>

        <section class="mb-14">
            <h2 class="text-xl font-semibold mb-4">
                {t.architectureComparison.goal.title}
            </h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.architectureComparison.goal.p1}
            </p>

            <p class="text-gray-600 dark:text-gray-400">
                {t.architectureComparison.goal.p2}
            </p>
        </section>

        <section class="mb-14">
            <h2 class="text-xl font-semibold mb-6">{t.architectureComparison.evaluation.title}</h2>

            <ul
                class="grid grid-cols-1 md:grid-cols-2 gap-3 text-gray-600 dark:text-gray-400 list-disc pl-6"
            >
                <li>{t.architectureComparison.evaluation.items[0]}</li>
                <li>{t.architectureComparison.evaluation.items[1]}</li>
                <li>{t.architectureComparison.evaluation.items[2]}</li>
                <li>{t.architectureComparison.evaluation.items[3]}</li>
                <li>{t.architectureComparison.evaluation.items[4]}</li>
                <li>{t.architectureComparison.evaluation.items[5]}</li>
                <li>{t.architectureComparison.evaluation.items[6]}</li>
            </ul>
        </section>

        <section class="mb-14">
            <h2 class="text-xl font-semibold mb-4">{t.architectureComparison.domain.title}</h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.architectureComparison.domain.p1}
            </p>

            <ul
                class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
            >
                <li>{t.architectureComparison.domain.items[0]}</li>
                <li>{t.architectureComparison.domain.items[1]}</li>
                <li>{t.architectureComparison.domain.items[2]}</li>
                <li>{t.architectureComparison.domain.items[3]}</li>
            </ul>
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">{t.architectureComparison.architectures.title}</h2>

            <div class="space-y-6">
                <div
                    class="border border-gray-200 dark:border-gray-800 rounded-xl p-6"
                >
                    <h3 class="font-semibold mb-2">
                        {t.architectureComparison.phases.title}
                    </h3>

                    <p class="text-gray-600 dark:text-gray-400 text-sm mb-2">
                        Pure Active Record approach using Eloquent directly.
                    </p>

                    <p class="text-gray-600 dark:text-gray-400 text-sm">
                        Fast to develop but tightly coupled to the framework.
                        Complexity grows rapidly as domain rules increase.
                    </p>
                </div>

                <div
                    class="border border-gray-200 dark:border-gray-800 rounded-xl p-6"
                >
                    <h3 class="font-semibold mb-2">A02 — Repository Pattern</h3>

                    <p class="text-gray-600 dark:text-gray-400 text-sm mb-2">
                        Separation between controller, service layer and
                        repository abstraction.
                    </p>

                    <p class="text-gray-600 dark:text-gray-400 text-sm">
                        Introduces dependency inversion and improves testability
                        while keeping a relatively simple domain model.
                    </p>
                </div>

                <div
                    class="border border-gray-200 dark:border-gray-800 rounded-xl p-6"
                >
                    <h3 class="font-semibold mb-2">
                        A03 — Strategy + Polymorphism
                    </h3>

                    <p class="text-gray-600 dark:text-gray-400 text-sm mb-2">
                        Reservation behaviour varies depending on reservation
                        type.
                    </p>

                    <p class="text-gray-600 dark:text-gray-400 text-sm">
                        Encapsulates business rules using polymorphism and
                        strategy objects, making the domain model more
                        expressive.
                    </p>
                </div>

                <div
                    class="border border-gray-200 dark:border-gray-800 rounded-xl p-6"
                >
                    <h3 class="font-semibold mb-2">A04 — Decorator Domain</h3>

                    <p class="text-gray-600 dark:text-gray-400 text-sm mb-2">
                        Behaviour is composed dynamically through decorators.
                    </p>

                    <p class="text-gray-600 dark:text-gray-400 text-sm">
                        Applies the Open/Closed principle allowing rules and
                        modifiers to be added without modifying existing logic.
                    </p>
                </div>
            </div>
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">{t.architectureComparison.phases.title}</h2>

            <div class="space-y-4 text-gray-600 dark:text-gray-400">
                <p>
                    <strong>Phase 01 — Base Calculation</strong><br />
                    {t.architectureComparison.phases.phase1}
                </p>

                <p>
                    <strong>Phase 02 — Conditional Rules</strong><br />
                    {t.architectureComparison.phases.phase2}
                </p>

                <p>
                    <strong>Phase 03 — Polymorphic Behaviour</strong><br />
                    {t.architectureComparison.phases.phase3}
                </p>

                <p>
                    <strong>Phase 04 — Composable Rules</strong><br />
                    {t.architectureComparison.phases.phase4}
                </p>
            </div>
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">{t.architectureComparison.criteria.title}</h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.architectureComparison.criteria.p1}
            </p>

            <ul
                class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
            >
                <li>{t.architectureComparison.criteria.items[0]}</li>
                <li>{t.architectureComparison.criteria.items[1]}</li>
                <li>{t.architectureComparison.criteria.items[2]}</li>
                <li>{t.architectureComparison.criteria.items[3]}</li>
                <li>{t.architectureComparison.criteria.items[4]}</li>
                <li>{t.architectureComparison.criteria.items[5]}</li>
            </ul>
        </section>

        <section class="mb-14">
            <h2 class="text-xl font-semibold mb-4">{t.architectureComparison.philosophy.title}</h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.architectureComparison.philosophy.p1}
            </p>

            <p class="text-gray-600 dark:text-gray-400">
                {t.architectureComparison.philosophy.p2}
            </p>
        </section>

        <section>
            <h2 class="text-xl font-semibold mb-4">{t.architectureComparison.purpose.title}</h2>

            <p class="text-gray-600 dark:text-gray-400">
                {t.architectureComparison.purpose.p1}
            </p>
        </section>
    </article>
</BaseLayout>
