---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BackLink from "../../components/BackLink.astro";

import { getLangFromUrl } from "../../i18n/getLang";
import { getTranslations } from "../../i18n";

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
---

<BaseLayout>
    <article class="max-w-3xl mx-auto">
        <BackLink href="/projects" label={t.architectureComparison.back} />

        <header class="mb-14">
            <h1 class="text-3xl md:text-4xl font-bold mb-4">
                {t.architectureComparison.header.title}
            </h1>

            <p class="text-lg text-gray-600 dark:text-gray-400">
                {t.architectureComparison.header.description}
            </p>
        </header>

        <section class="mb-14">
            <h2 class="text-xl font-semibold mb-4">
                {t.architectureComparison.goal.title}
            </h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.architectureComparison.goal.p1}
            </p>

            <p class="text-gray-600 dark:text-gray-400">
                {t.architectureComparison.goal.p2}
            </p>
        </section>

        <section class="mb-14">
            <h2 class="text-xl font-semibold mb-6">{t.architectureComparison.evaluation.title}</h2>

            <ul
                class="grid grid-cols-1 md:grid-cols-2 gap-3 text-gray-600 dark:text-gray-400 list-disc pl-6"
            >
                <li>{t.architectureComparison.evaluation.items[0]}</li>
                <li>{t.architectureComparison.evaluation.items[1]}</li>
                <li>{t.architectureComparison.evaluation.items[2]}</li>
                <li>{t.architectureComparison.evaluation.items[3]}</li>
                <li>{t.architectureComparison.evaluation.items[4]}</li>
                <li>{t.architectureComparison.evaluation.items[5]}</li>
                <li>{t.architectureComparison.evaluation.items[6]}</li>
            </ul>
        </section>

        <section class="mb-14">
            <h2 class="text-xl font-semibold mb-4">{t.architectureComparison.domain.title}</h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.architectureComparison.domain.p1}
            </p>

            <ul
                class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
            >
                <li>{t.architectureComparison.domain.items[0]}</li>
                <li>{t.architectureComparison.domain.items[1]}</li>
                <li>{t.architectureComparison.domain.items[2]}</li>
                <li>{t.architectureComparison.domain.items[3]}</li>
            </ul>
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">{t.architectureComparison.architectures.title}</h2>

            <div class="space-y-6">
                <div 
                    class="arch-gradient border border-gray-200 dark:border-gray-800 rounded-xl p-6 bg-gradient-to-br from-blue-500/10 via-transparent to-blue-400/10"
                >
                    <h3 class="font-semibold mb-2">
                        {t.architectureComparison.architectures.a01.name}
                    </h3>

                    <p class="text-gray-600 dark:text-gray-400 text-sm mb-2">
                        {t.architectureComparison.architectures.a01.summary}
                    </p>

                    <p class="text-gray-600 dark:text-gray-400 text-sm">
                        {t.architectureComparison.architectures.a01.description}
                    </p>
                </div>

                <div 
                    class="arch-gradient border border-gray-200 dark:border-gray-800 rounded-xl p-6 bg-gradient-to-br from-purple-500/10 via-transparent to-purple-400/10"
                >
                    <h3 class="font-semibold mb-2">{t.architectureComparison.architectures.a02.name}</h3>

                    <p class="text-gray-600 dark:text-gray-400 text-sm mb-2">
                        {t.architectureComparison.architectures.a02.summary}
                    </p>

                    <p class="text-gray-600 dark:text-gray-400 text-sm">
                        {t.architectureComparison.architectures.a02.description}
                    </p>
                </div>

                <div 
                    class="arch-gradient border border-gray-200 dark:border-gray-800 rounded-xl p-6 bg-gradient-to-br from-emerald-500/10 via-transparent to-emerald-400/10"
                >
                    <h3 class="font-semibold mb-2">
                        {t.architectureComparison.architectures.a03.name}
                    </h3>

                    <p class="text-gray-600 dark:text-gray-400 text-sm mb-2">
                        {t.architectureComparison.architectures.a03.summary}
                    </p>

                    <p class="text-gray-600 dark:text-gray-400 text-sm">
                        {t.architectureComparison.architectures.a03.description}
                    </p>
                </div>

                <div 
                    class="arch-gradient border border-gray-200 dark:border-gray-800 rounded-xl p-6 bg-gradient-to-br from-amber-500/10 via-transparent to-amber-400/10"
                >
                    <h3 class="font-semibold mb-2">{t.architectureComparison.architectures.a04.name}</h3>

                    <p class="text-gray-600 dark:text-gray-400 text-sm mb-2">
                        {t.architectureComparison.architectures.a04.summary}
                    </p>

                    <p class="text-gray-600 dark:text-gray-400 text-sm">
                        {t.architectureComparison.architectures.a04.description}
                    </p>
                </div>
            </div>
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">
                {t.architectureComparison.phases.title}
            </h2>

            <ul class="space-y-6 border-l border-gray-200 dark:border-gray-800 pl-4">

                <li class="flex flex-col">
                <span class="font-medium text-gray-900 dark:text-gray-100">
                    {t.architectureComparison.phases.phase1Title}
                </span>

                <span class="text-sm text-gray-600 dark:text-gray-400 ml-4">
                    {t.architectureComparison.phases.phase1}
                </span>
                </li>

                <li class="flex flex-col">
                <span class="font-medium text-gray-900 dark:text-gray-100">
                    {t.architectureComparison.phases.phase2Title}
                </span>

                <span class="text-sm text-gray-600 dark:text-gray-400 ml-4">
                    {t.architectureComparison.phases.phase2}
                </span>
                </li>

                <li class="flex flex-col">
                <span class="font-medium text-gray-900 dark:text-gray-100">
                    {t.architectureComparison.phases.phase3Title}
                </span>

                <span class="text-sm text-gray-600 dark:text-gray-400 ml-4">
                    {t.architectureComparison.phases.phase3}
                </span>
                </li>

                <li class="flex flex-col">
                <span class="font-medium text-gray-900 dark:text-gray-100">
                    {t.architectureComparison.phases.phase4Title}
                </span>

                <span class="text-sm text-gray-600 dark:text-gray-400 ml-4">
                    {t.architectureComparison.phases.phase4}
                </span>
                </li>

            </ul>
            </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">{t.architectureComparison.criteria.title}</h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.architectureComparison.criteria.p1}
            </p>

            <ul
                class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
            >
                <li>{t.architectureComparison.criteria.items[2]}</li>
                <li>{t.architectureComparison.criteria.items[3]}</li>
                <li>{t.architectureComparison.criteria.items[4]}</li>
                <li>{t.architectureComparison.criteria.items[5]}</li>
            </ul>
        </section>

        <section class="mb-14">
            <h2 class="text-xl font-semibold mb-4">{t.architectureComparison.philosophy.title}</h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.architectureComparison.philosophy.p1}
            </p>

            <p class="text-gray-600 dark:text-gray-400">
                {t.architectureComparison.philosophy.p2}
            </p>
        </section>

        <section>
            <h2 class="text-xl font-semibold mb-4">{t.architectureComparison.purpose.title}</h2>

            <p class="text-gray-600 dark:text-gray-400">
                {t.architectureComparison.purpose.p1}
            </p>
        </section>
    </article>
</BaseLayout>
