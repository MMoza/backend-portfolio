                        {t.designAntipatterns.categories_section.naming.title}
                    </h3>
                    <ul
                        class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
                    >
                        {t.designAntipatterns.categories_section.naming.items.map((item) => (
                            <li>{item}</li>
                        ))}
                    </ul>
                </div>

                <div>
                    <h3 class="font-semibold mb-3 text-blue-600 dark:text-blue-400">
                        {t.designAntipatterns.categories_section.integrations.title}
                    </h3>
                    <ul
                        class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
                    >
                        {t.designAntipatterns.categories_section.integrations.items.map((item) => (
                            <li>{item}</li>
                        ))}
                    </ul>
                </div>

                <div>
                    <h3 class="font-semibold mb-3 text-blue-600 dark:text-blue-400">
                        {t.designAntipatterns.categories_section.concurrency.title}
                    </h3>
                    <ul
                        class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
                    >
                        {t.designAntipatterns.categories_section.concurrency.items.map((item) => (
                            <li>{item}</li>
                        ))}
                    </ul>
                </div>

                <div>
                    <h3 class="font-semibold mb-3 text-blue-600 dark:text-blue-400">
                        {t.designAntipatterns.categories_section.performance.title}
                    </h3>
                    <ul
                        class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
                    >
                        {t.designAntipatterns.categories_section.performance.items.map((item) => (
                            <li>{item}</li>
                        ))}
                    </ul>
                </div>

                <div>
                    <h3 class="font-semibold mb-3 text-blue-600 dark:text-blue-400">
                        {t.designAntipatterns.categories_section.observability.title}
                    </h3>
                    <ul
                        class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
                    >
                        {t.designAntipatterns.categories_section.observability.items.map((item) => (
                            <li>{item}</li>
                        ))}
                    </ul>
                </div>

                <div>
                    <h3 class="font-semibold mb-3 text-blue-600 dark:text-blue-400">
                        {t.designAntipatterns.categories_section.framework.title}
                    </h3>
                    <ul
                        class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
                    >
                        {t.designAntipatterns.categories_section.framework.items.map((item) => (
                            <li>{item}</li>
                        ))}
                    </ul>
                </div>

                <div>
                    <h3 class="font-semibold mb-3 text-blue-600 dark:text-blue-400">
                        {t.designAntipatterns.categories_section.deployment.title}
                    </h3>
                    <ul
                        class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
                    >
                        {t.designAntipatterns.categories_section.deployment.items.map((item) => (
                            <li>{item}</li>
                        ))}
                    </ul>
                </div>

                <div>
                    <h3 class="font-semibold mb-3 text-blue-600 dark:text-blue-400">
                        {t.designAntipatterns.categories_section.testing.title}
                    </h3>
                    <ul
                        class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
                    >
                        {t.designAntipatterns.categories_section.testing.items.map((item) => (
                            <li>{item}</li>
                        ))}
                    </ul>
                </div>

                <div>
                    <h3 class="font-semibold mb-3 text-blue-600 dark:text-blue-400">
                        {t.designAntipatterns.categories_section.domain.title}
                    </h3>
                    <ul
                        class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
                    >
                        {t.designAntipatterns.categories_section.domain.items.map((item) => (
                            <li>{item}</li>
                        ))}
                    </ul>
                </div>

                <div>
                    <h3 class="font-semibold mb-3 text-blue-600 dark:text-blue-400">
                        {t.designAntipatterns.categories_section.sociotechnical.title}
                    </h3>
                    <ul
