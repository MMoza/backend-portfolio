            </div>
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">
                {t.designAntipatterns.methodology_section.title}
            </h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.designAntipatterns.methodology_section.p1}
            </p>

            <p class="text-gray-600 dark:text-gray-400">
                {t.designAntipatterns.methodology_section.p2}
            </p>
        </section>

        <section>
            <h2 class="text-xl font-semibold mb-6">
                {t.designAntipatterns.next_steps_section.title}
            </h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.designAntipatterns.next_steps_section.p1}
            </p>

            <ul
                class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
            >
                <li>{t.designAntipatterns.next_steps_section.items[0]}</li>
                <li>{t.designAntipatterns.next_steps_section.items[1]}</li>
                <li>{t.designAntipatterns.next_steps_section.items[2]}</li>
                <li>{t.designAntipatterns.next_steps_section.items[3]}</li>
                <li>{t.designAntipatterns.next_steps_section.items[4]}</li>
                <li>{t.designAntipatterns.next_steps_section.items[5]}</li>
