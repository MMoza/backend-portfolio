---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MetricCard from "../../components/MetricCard.astro";
import BackLink from "../../components/BackLink.astro";

import { getLangFromUrl } from "../../i18n/getLang";
import { getTranslations } from "../../i18n";

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
---

<BaseLayout>
    <article class="max-w-3xl mx-auto">
        <BackLink href="/projects" label={t.randomuserTechnicalTest.back} />

        <header class="mb-14">
            <p class="text-sm text-gray-500 mb-2">{t.randomuserTechnicalTest.header.label}</p>

            <h1 class="text-3xl md:text-4xl font-bold mb-4">
                {t.randomuserTechnicalTest.header.title}
            </h1>

            <p class="text-lg text-gray-600 dark:text-gray-400">
                {t.randomuserTechnicalTest.header.description}
            </p>
        </header>

        <section class="mb-16">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-10">
                <div
                    class="group border border-gray-200 dark:border-gray-800 rounded-lg p-5
                            bg-white/95 dark:bg-gray-900/95
                            backdrop-blur-sm
                            flex flex-col h-full
                            transition-all duration-300
                            hover:-translate-y-1 hover:shadow-lg
                            hover:border-blue-500/40"
                >
                    <p
                        class="font-semibold text-gray-800 dark:text-gray-200 mb-1"
                    >
                        {t.randomuserTechnicalTest.highlights.api.title}
                    </p>

                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-auto">
                        {t.randomuserTechnicalTest.highlights.api.description}
                    </p>
                </div>

                <div
                    class="group border border-gray-200 dark:border-gray-800 rounded-lg p-5
                            bg-white/95 dark:bg-gray-900/95
                            backdrop-blur-sm
                            flex flex-col h-full
                            transition-all duration-300
                            hover:-translate-y-1 hover:shadow-lg
                            hover:border-blue-500/40"
                >
                    <p
                        class="font-semibold text-gray-800 dark:text-gray-200 mb-1"
                    >
                        {t.randomuserTechnicalTest.highlights.communication.title}
                    </p>

                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-auto">
                        {t.randomuserTechnicalTest.highlights.communication.description}
                    </p>
                </div>

                <div
                    class="group border border-gray-200 dark:border-gray-800 rounded-lg p-5
                            bg-white/95 dark:bg-gray-900/95
                            backdrop-blur-sm
                            flex flex-col h-full
                            transition-all duration-300
                            hover:-translate-y-1 hover:shadow-lg
                            hover:border-blue-500/40"
                >
                    <p
                        class="font-semibold text-gray-800 dark:text-gray-200 mb-1"
                    >
                        {t.randomuserTechnicalTest.highlights.assessment.title}
                    </p>

                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-auto">
                        {t.randomuserTechnicalTest.highlights.assessment.description}
                    </p>
                </div>
            </div>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.randomuserTechnicalTest.intro.p1}
                <a
                    href="https://randomuser.me/documentation"
                    target="_blank"
                    class="text-blue-600 dark:text-blue-400 hover:underline underline-offset-2 transition-colors"
                    >
                    RandomUser API 
                </a>
            </p>

            <p class="text-gray-600 dark:text-gray-400">
                {t.randomuserTechnicalTest.intro.p2}
            </p>
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">{t.randomuserTechnicalTest.objectives_section.title}</h2>

            <ul
                class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
            >
                <li>{t.randomuserTechnicalTest.objectives_section.items[0]}</li>
                <li>{t.randomuserTechnicalTest.objectives_section.items[1]}</li>
                <li>{t.randomuserTechnicalTest.objectives_section.items[2]}</li>
                <li>{t.randomuserTechnicalTest.objectives_section.items[3]}</li>
                <li>{t.randomuserTechnicalTest.objectives_section.items[4]}</li>
            </ul>
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">
                {t.randomuserTechnicalTest.architecture_section.title}
            </h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.randomuserTechnicalTest.architecture_section.intro}
            </p>

            <ul
                class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
            >
                <li>
                    {t.randomuserTechnicalTest.architecture_section.items[0]}
                </li>

                <li>{t.randomuserTechnicalTest.architecture_section.items[1]}</li>

                <li>
                    {t.randomuserTechnicalTest.architecture_section.items[2]}
                </li>

                <li>
                    {t.randomuserTechnicalTest.architecture_section.items[3]}
                </li>
            </ul>
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">{t.randomuserTechnicalTest.backend_section.title}</h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.randomuserTechnicalTest.backend_section.p1}
            </p>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.randomuserTechnicalTest.backend_section.p2}
            </p>

            <p class="text-gray-600 dark:text-gray-400">
                {t.randomuserTechnicalTest.backend_section.p3}
            </p>
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">{t.randomuserTechnicalTest.frontend_section.title}</h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.randomuserTechnicalTest.frontend_section.p1}
            </p>

            <p class="text-gray-600 dark:text-gray-400">
                {t.randomuserTechnicalTest.frontend_section.p2}
            </p>
        </section>

        <section class="mb-14">
            <h2 class="text-xl font-semibold mb-6">{t.randomuserTechnicalTest.learning_section.title}</h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.randomuserTechnicalTest.learning_section.p1}
            </p>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.randomuserTechnicalTest.learning_section.p2}
            </p>

            <p class="text-gray-600 dark:text-gray-400">
                {t.randomuserTechnicalTest.learning_section.p3}
            </p>
        </section>
    </article>
</BaseLayout>
