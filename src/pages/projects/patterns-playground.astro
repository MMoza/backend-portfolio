---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BackLink from "../../components/BackLink.astro";

import { getLangFromUrl } from "../../i18n/getLang";
import { getTranslations } from "../../i18n";

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
---

<BaseLayout>
    <article class="max-w-3xl mx-auto">
        <BackLink href="/projects" label={t.patternsPlayground.back} />

        <header class="mb-14">
            <p class="text-sm text-gray-500 mb-2">{t.patternsPlayground.header.label}</p>

            <h1 class="text-3xl md:text-4xl font-bold mb-4">
                {t.patternsPlayground.header.title}
            </h1>

            <p class="text-lg text-gray-600 dark:text-gray-400">
                {t.patternsPlayground.header.description}
            </p>
        </header>

        <section class="mb-16">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-10">
                <div
                    class="border border-gray-200 dark:border-gray-800 rounded-lg p-5 bg-white/95 dark:bg-gray-900/95 backdrop-blur-sm flex flex-col h-full transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-blue-500/40"
                >
                    <p
                        class="font-semibold text-gray-800 dark:text-gray-200 mb-1"
                    >
                        {t.patternsPlayground.highlights.architecture.title}
                    </p>

                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-auto">
                        {t.patternsPlayground.highlights.architecture.description}
                    </p>
                </div>

                <div
                    class="border border-gray-200 dark:border-gray-800 rounded-lg p-5 bg-white/95 dark:bg-gray-900/95 backdrop-blur-sm flex flex-col h-full transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-blue-500/40"
                >
                    <p
                        class="font-semibold text-gray-800 dark:text-gray-200 mb-1"
                    >
                        {t.patternsPlayground.highlights.laravel.title}
                    </p>

                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-auto">
                        {t.patternsPlayground.highlights.laravel.description}
                    </p>
                </div>

                <div
                    class="border border-gray-200 dark:border-gray-800 rounded-lg p-5 bg-white/95 dark:bg-gray-900/95 backdrop-blur-sm flex flex-col h-full transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-blue-500/40"
                >
                    <p
                        class="font-semibold text-gray-800 dark:text-gray-200 mb-1"
                    >
                        {t.patternsPlayground.highlights.learning.title}
                    </p>

                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-auto">
                        {t.patternsPlayground.highlights.learning.description}
                    </p>
                </div>
            </div>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.patternsPlayground.intro.p1}
            </p>

            <p class="text-gray-600 dark:text-gray-400">
                {t.patternsPlayground.intro.p2}
            </p>
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">{t.patternsPlayground.goals_section.title}</h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.patternsPlayground.goals_section.p1}
            </p>

            <ul
                class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
            >
                <li>{t.patternsPlayground.goals_section.items[0]}</li>
                <li>{t.patternsPlayground.goals_section.items[1]}</li>
                <li>{t.patternsPlayground.goals_section.items[2]}</li>
                <li>{t.patternsPlayground.goals_section.items[3]}</li>
            </ul>
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">{t.patternsPlayground.patterns_section.title}</h2>

            <p class="text-gray-600 dark:text-gray-400 mb-6">
                {t.patternsPlayground.patterns_section.intro}
            </p>

            <h3 class="font-semibold mb-3">{t.patternsPlayground.patterns_section.creational.title}</h3>

            <ul
                class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6 mb-6"
            >
                <li>{t.patternsPlayground.patterns_section.creational.items[0]}</li>
                <li>{t.patternsPlayground.patterns_section.creational.items[1]}</li>
                <li>{t.patternsPlayground.patterns_section.creational.items[2]}</li>
            </ul>

            <h3 class="font-semibold mb-3">{t.patternsPlayground.patterns_section.structural.title}</h3>

            <ul
                class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6 mb-6"
            >
                <li>{t.patternsPlayground.patterns_section.structural.items[0]}</li>
                <li>{t.patternsPlayground.patterns_section.structural.items[1]}</li>
                <li>{t.patternsPlayground.patterns_section.structural.items[2]}</li>
            </ul>

            <h3 class="font-semibold mb-3">{t.patternsPlayground.patterns_section.behavioral.title}</h3>

            <ul
                class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
            >
                <li>{t.patternsPlayground.patterns_section.behavioral.items[0]}</li>
                <li>{t.patternsPlayground.patterns_section.behavioral.items[1]}</li>
                <li>{t.patternsPlayground.patterns_section.behavioral.items[2]}</li>
            </ul>
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">{t.patternsPlayground.why_laravel_section.title}</h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.patternsPlayground.why_laravel_section.p1}
            </p>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.patternsPlayground.why_laravel_section.p2}
            </p>

            <p class="text-gray-600 dark:text-gray-400">
                {t.patternsPlayground.why_laravel_section.p3}
            </p>
        </section>

        <section>
            <h2 class="text-xl font-semibold mb-6">{t.patternsPlayground.learning_approach_section.title}</h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.patternsPlayground.learning_approach_section.p1}
            </p>

            <p class="text-gray-600 dark:text-gray-400">
                {t.patternsPlayground.learning_approach_section.p2}
            </p>
        </section>
    </article>
</BaseLayout>
