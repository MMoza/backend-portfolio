---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BackLink from "../../../components/BackLink.astro";

import { getLangFromUrl } from "../../../i18n/getLang";
import { getTranslations } from "../../../i18n";

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
const langPrefix = lang === "es" ? "/es" : "";
---

<BaseLayout>
  <article class="max-w-4xl mx-auto">
    <BackLink href="/projects/architecture-comparison" label={t.architectureComparison.architectureDetail.back} />

    <!-- Hero Section -->
    <header class="mb-12">
      <div
        class="rounded-xl p-8 md:p-12 bg-gradient-to-br from-emerald-500/10 via-transparent to-emerald-400/5 border border-emerald-200 dark:border-emerald-900"
      >
        <h1 class="text-4xl md:text-5xl font-bold mb-4 text-gray-900 dark:text-gray-100">
          {t.architectureComparison.architectureDetail.a03.title}
        </h1>

        <p class="text-lg text-gray-600 dark:text-gray-400 mb-6">
          {t.architectureComparison.architectureDetail.a03.subtitle}
        </p>

        <div class="space-y-2">
          <p class="text-sm">
            <span class="font-semibold text-gray-900 dark:text-gray-100">{t.architectureComparison.architectureDetail.pattern}:</span>
            <span class="text-gray-600 dark:text-gray-400">{t.architectureComparison.architectureDetail.a03.patternValue}</span>
          </p>
          <p class="text-sm">
            <span class="font-semibold text-gray-900 dark:text-gray-100">{t.architectureComparison.architectureDetail.philosophy}:</span>
            <span class="text-gray-600 dark:text-gray-400">{t.architectureComparison.architectureDetail.a03.philosophyValue}</span>
          </p>
        </div>
      </div>
    </header>

    <!-- Description Section -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4 text-gray-900 dark:text-gray-100">
        {t.architectureComparison.architectureDetail.description}
      </h2>

      <div class="prose dark:prose-invert max-w-none">
        <p class="text-gray-600 dark:text-gray-400 mb-4">
          {t.architectureComparison.architectureDetail.a03.description}
        </p>

        <p class="text-gray-600 dark:text-gray-400 mb-4">
          <span class="font-semibold text-gray-900 dark:text-gray-100">{t.architectureComparison.architectureDetail.a03.strengths.header}</span>
        </p>
        <ul class="list-disc pl-6 text-gray-600 dark:text-gray-400 mb-4 space-y-2">
          {t.architectureComparison.architectureDetail.a03.strengths.items.map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>

        <p class="text-gray-600 dark:text-gray-400 mb-4">
          <span class="font-semibold text-gray-900 dark:text-gray-100">{t.architectureComparison.architectureDetail.a03.weaknesses.header}</span>
        </p>
        <ul class="list-disc pl-6 text-gray-600 dark:text-gray-400 mb-4 space-y-2">
          {t.architectureComparison.architectureDetail.a03.weaknesses.items.map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Evolution Table -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6 text-gray-900 dark:text-gray-100">
        {t.architectureComparison.architectureDetail.evolution}
      </h2>

      <div class="overflow-x-auto rounded-lg border border-gray-200 dark:border-gray-800">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800">
            <tr>
              <th class="px-6 py-3 text-left font-semibold text-gray-900 dark:text-gray-100">
                {t.architectureComparison.architectureDetail.metricsTable.phase}
              </th>
              <th class="px-6 py-3 text-left font-semibold text-gray-900 dark:text-gray-100">
                {t.architectureComparison.architectureDetail.metricsTable.files}
              </th>
              <th class="px-6 py-3 text-left font-semibold text-gray-900 dark:text-gray-100">
                {t.architectureComparison.architectureDetail.metricsTable.lines}
              </th>
              <th class="px-6 py-3 text-left font-semibold text-gray-900 dark:text-gray-100">
                {t.architectureComparison.architectureDetail.metricsTable.controller}
              </th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-200 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-900/50">
              <td class="px-6 py-4 font-semibold text-gray-900 dark:text-gray-100">{t.architectureComparison.architectureDetail.metricsTable.phase01}</td>
              <td class="px-6 py-4 text-gray-600 dark:text-gray-400">14</td>
              <td class="px-6 py-4 text-gray-600 dark:text-gray-400">371</td>
              <td class="px-6 py-4 text-gray-600 dark:text-gray-400">31</td>
            </tr>
            <tr class="border-b border-gray-200 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-900/50">
              <td class="px-6 py-4 font-semibold text-gray-900 dark:text-gray-100">{t.architectureComparison.architectureDetail.metricsTable.phase02}</td>
              <td class="px-6 py-4 text-gray-600 dark:text-gray-400">14</td>
              <td class="px-6 py-4 text-gray-600 dark:text-gray-400">523</td>
              <td class="px-6 py-4 text-gray-600 dark:text-gray-400">32</td>
            </tr>
            <tr class="border-b border-gray-200 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-900/50">
              <td class="px-6 py-4 font-semibold text-gray-900 dark:text-gray-100">{t.architectureComparison.architectureDetail.metricsTable.phase03}</td>
              <td class="px-6 py-4 text-gray-600 dark:text-gray-400">14</td>
              <td class="px-6 py-4 text-gray-600 dark:text-gray-400">727</td>
              <td class="px-6 py-4 text-gray-600 dark:text-gray-400">32</td>
            </tr>
            <tr class="border-b border-gray-200 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-900/50">
              <td class="px-6 py-4 font-semibold text-gray-900 dark:text-gray-100">{t.architectureComparison.architectureDetail.metricsTable.phase04}</td>
              <td class="px-6 py-4 text-gray-600 dark:text-gray-400">14</td>
              <td class="px-6 py-4 text-gray-600 dark:text-gray-400">775</td>
              <td class="px-6 py-4 text-green-600 dark:text-green-400">32</td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="mt-6 p-4 rounded-lg bg-yellow-50 dark:bg-yellow-950/30 border border-yellow-200 dark:border-yellow-900 text-yellow-900 dark:text-yellow-200">
        <span class="font-semibold">{t.architectureComparison.architectureDetail.a03.warning.label}:</span> {t.architectureComparison.architectureDetail.a03.warning.message}
      </p>
    </section>

    <!-- Key Metrics Section -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6 text-gray-900 dark:text-gray-100">
        {t.architectureComparison.architectureDetail.metrics}
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="rounded-lg border border-gray-200 dark:border-gray-800 p-6">
          <p class="text-sm text-gray-500 dark:text-gray-500 mb-2">{t.architectureComparison.architectureDetail.a03.metrics.totalFiles.label}</p>
          <p class="text-3xl font-bold text-gray-900 dark:text-gray-100">{t.architectureComparison.architectureDetail.a03.metrics.totalFiles.value}</p>
          <p class="text-xs text-gray-600 dark:text-gray-400 mt-2">{t.architectureComparison.architectureDetail.a03.metrics.totalFiles.note}</p>
        </div>

        <div class="rounded-lg border border-gray-200 dark:border-gray-800 p-6">
          <p class="text-sm text-gray-500 dark:text-gray-500 mb-2">{t.architectureComparison.architectureDetail.a03.metrics.totalLines.label}</p>
          <p class="text-3xl font-bold text-gray-900 dark:text-gray-100">{t.architectureComparison.architectureDetail.a03.metrics.totalLines.value}</p>
          <p class="text-xs text-gray-600 dark:text-gray-400 mt-2">{t.architectureComparison.architectureDetail.a03.metrics.totalLines.note}</p>
        </div>

        <div class="rounded-lg border border-gray-200 dark:border-gray-800 p-6">
          <p class="text-sm text-gray-500 dark:text-gray-500 mb-2">{t.architectureComparison.architectureDetail.a03.metrics.controllerSize.label}</p>
          <p class="text-3xl font-bold text-green-600 dark:text-green-400">{t.architectureComparison.architectureDetail.a03.metrics.controllerSize.value}</p>
          <p class="text-xs text-gray-600 dark:text-gray-400 mt-2">{t.architectureComparison.architectureDetail.a03.metrics.controllerSize.note}</p>
        </div>

        <div class="rounded-lg border border-gray-200 dark:border-gray-800 p-6">
          <p class="text-sm text-gray-500 dark:text-gray-500 mb-2">{t.architectureComparison.architectureDetail.a03.metrics.testability.label}</p>
          <p class="text-3xl font-bold text-gray-900 dark:text-gray-100">{t.architectureComparison.architectureDetail.a03.metrics.testability.value}</p>
          <p class="text-xs text-gray-600 dark:text-gray-400 mt-2">{t.architectureComparison.architectureDetail.a03.metrics.testability.note}</p>
        </div>
      </div>
    </section>

    <!-- Conclusion Section -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4 text-gray-900 dark:text-gray-100">
        {t.architectureComparison.architectureDetail.conclusion}
      </h2>

      <div class="rounded-lg border border-emerald-200 dark:border-emerald-900 bg-emerald-50 dark:bg-emerald-950/30 p-6">
        <p class="text-emerald-900 dark:text-emerald-200 mb-4">
          <span class="font-semibold">{t.architectureComparison.architectureDetail.a03.conclusion.bold}</span>
        </p>
        {t.architectureComparison.architectureDetail.a03.conclusion.paragraphs.map((paragraph: string) => (
          <p class="text-emerald-900 dark:text-emerald-200 mb-4">{paragraph}</p>
        ))}
      </div>
    </section>

    <!-- When to Use Section -->
    <section class="mb-12 p-6 rounded-lg bg-blue-50 dark:bg-blue-950/30 border border-blue-200 dark:border-blue-900">
      <h3 class="text-lg font-semibold text-blue-900 dark:text-blue-200 mb-4">
        {t.architectureComparison.architectureDetail.a03.whenToUse.title}
      </h3>
      <ul class="list-disc pl-6 text-blue-900 dark:text-blue-200 space-y-2">
        {t.architectureComparison.architectureDetail.a03.whenToUse.items.map((item: string) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>

    <!-- Footer -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-8 border-t border-gray-200 dark:border-gray-800">
      <BackLink href="/projects/architecture-comparison" label={t.architectureComparison.architectureDetail.back} />

      <a
        href="https://github.com/MMoza/reservations/tree/main/app/Architectures/A03_StrategyPolymorphism"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="w-5 h-5"
        >
          <path d="M12 0C5.37 0 0 5.37 0 12a12 12 0 008.21 11.38c.6.11.82-.26.82-.58v-2.02c-3.34.73-4.04-1.61-4.04-1.61-.55-1.38-1.33-1.75-1.33-1.75-1.09-.75.08-.74.08-.74 1.2.08 1.84 1.23 1.84 1.23 1.07 1.84 2.8 1.31 3.48 1 .11-.77.42-1.31.76-1.61-2.66-.3-5.46-1.33-5.46-5.93 0-1.31.47-2.38 1.23-3.22-.12-.3-.53-1.52.12-3.18 0 0 1-.32 3.3 1.23a11.4 11.4 0 016 0C17.3 3.6 18.3 3.92 18.3 3.92c.65 1.66.24 2.88.12 3.18.76.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.62-5.47 5.92.43.37.82 1.1.82 2.22v3.29c0 .32.21.7.83.58A12 12 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        <span class="text-sm">{t.architectureComparison.architectureDetail.source}</span>
      </a>
    </div>
  </article>
</BaseLayout>
