---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BackLink from "../../../components/BackLink.astro";

import { getLangFromUrl } from "../../../i18n/getLang";
import { getTranslations } from "../../../i18n";

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
const langPrefix = lang === "es" ? "/es" : "";

---

<BaseLayout>
  <article class="max-w-6xl mx-auto">
    <BackLink href="/projects" label={t.architectureComparison.back} />
    
    <!-- Hero Section -->
    <section class="mb-16">
      <header
        class="rounded-xl p-8 md:p-12 bg-gradient-to-br from-blue-500/10 via-purple-500/5 to-transparent border border-gray-200 dark:border-gray-800"
      >
        <h1 class="text-4xl md:text-5xl font-bold mb-4 text-gray-900 dark:text-gray-100">
          {t.architectureComparison.hero.title}
        </h1>

        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400 mb-8">
          {t.architectureComparison.hero.subtitle}
        </p>

        <!-- Badges -->
        <div class="flex flex-wrap gap-2 mb-8">
          {t.architectureComparison.hero.badges.map((badge: string) => (
            <span
              class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-200 dark:border-gray-700"
            >
              {badge}
            </span>
          ))}
        </div>

        <!-- CTA Button -->
        <a
          href="https://github.com/MMoza/reservations"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="w-5 h-5"
          >
            <path d="M12 0C5.37 0 0 5.37 0 12a12 12 0 008.21 11.38c.6.11.82-.26.82-.58v-2.02c-3.34.73-4.04-1.61-4.04-1.61-.55-1.38-1.33-1.75-1.33-1.75-1.09-.75.08-.74.08-.74 1.2.08 1.84 1.23 1.84 1.23 1.07 1.84 2.8 1.31 3.48 1 .11-.77.42-1.31.76-1.61-2.66-.3-5.46-1.33-5.46-5.93 0-1.31.47-2.38 1.23-3.22-.12-.3-.53-1.52.12-3.18 0 0 1-.32 3.3 1.23a11.4 11.4 0 016 0C17.3 3.6 18.3 3.92 18.3 3.92c.65 1.66.24 2.88.12 3.18.76.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.62-5.47 5.92.43.37.82 1.1.82 2.22v3.29c0 .32.21.7.83.58A12 12 0 0024 12c0-6.63-5.37-12-12-12z" />
          </svg>
          {t.architectureComparison.hero.cta}
        </a>
      </header>
    </section>

    <!-- The Experiment Section -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold mb-6 text-gray-900 dark:text-gray-100">
        {t.architectureComparison.experiment.title}
      </h2>

      <p class="text-gray-600 dark:text-gray-400 mb-4 text-lg">
        {t.architectureComparison.experiment.description}
      </p>

      <blockquote class="border-l-4 border-blue-500 pl-6 py-4 mb-8">
        <p class="text-xl font-medium text-gray-900 dark:text-gray-100 italic">
          {t.architectureComparison.experiment.question}
        </p>
      </blockquote>

      <!-- Architecture Cards - Horizontal Scroll -->
      <div class="flex gap-6 overflow-x-auto pb-4 snap-x snap-mandatory">
        {["a01", "a02", "a03", "a04"].map((archId) => {
          const arch = t.architectureComparison.architectures[archId];
          const gradients = {
            a01: "from-blue-500/10 to-blue-400/5",
            a02: "from-purple-500/10 to-purple-400/5",
            a03: "from-emerald-500/10 to-emerald-400/5",
            a04: "from-amber-500/10 to-amber-400/5"
          };

          return (
            <a
              href={`${langPrefix}/projects/architecture-comparison/${archId}/`}
              class={`group arch-gradient flex-shrink-0 w-72 md:w-80 snap-start flex flex-col justify-between rounded-xl border border-gray-200 dark:border-gray-800 p-6 bg-gradient-to-br ${gradients[archId]} hover:shadow-lg hover:-translate-y-1 transition-all duration-300 cursor-pointer`}
            >
              <div>
                <h3 class="text-xl font-bold mb-2 text-gray-900 dark:text-gray-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                  {arch.name}
                </h3>

                <p class="text-sm text-gray-500 dark:text-gray-500 mb-3">
                  {arch.pattern}
                </p>

                <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
                  <span class="font-medium">Philosophy:</span> {arch.philosophy}
                </p>

                <p class="text-sm text-gray-600 dark:text-gray-400">
                  <span class="font-medium">Strength:</span> {arch.strength}
                </p>
              </div>

              <div class="flex items-center gap-2 text-blue-600 dark:text-blue-400 font-medium group-hover:gap-3 transition-all mt-4">
                {arch.link}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-4 h-4 group-hover:translate-x-1 transition-transform"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- Domain & Endpoints Section -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold mb-6 text-gray-900 dark:text-gray-100">
        {t.architectureComparison.domain.title}
      </h2>

      <p class="text-gray-600 dark:text-gray-400 mb-8 text-lg">
        {t.architectureComparison.domain.description}
      </p>

      <!-- Endpoints Table -->
      <div class="mb-8">
        <h3 class="text-xl font-semibold mb-4 text-gray-900 dark:text-gray-100">
          {t.architectureComparison.domain.endpointsTitle}
        </h3>

        <div class="overflow-x-auto rounded-lg border border-gray-200 dark:border-gray-800">
          <table class="w-full text-sm">
            <thead class="bg-gray-50 dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800">
              <tr>
                <th class="px-6 py-3 text-left font-semibold text-gray-900 dark:text-gray-100">
                  Method
                </th>
                <th class="px-6 py-3 text-left font-semibold text-gray-900 dark:text-gray-100">
                  Endpoint
                </th>
                <th class="px-6 py-3 text-left font-semibold text-gray-900 dark:text-gray-100">
                  Description
                </th>
              </tr>
            </thead>
            <tbody>
              {t.architectureComparison.domain.endpoints.map((endpoint: any) => (
                <tr class="border-b border-gray-200 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-900/50">
                  <td class="px-6 py-4 font-mono text-xs font-semibold text-blue-600 dark:text-blue-400">
                    {endpoint.method}
                  </td>
                  <td class="px-6 py-4 font-mono text-xs text-gray-600 dark:text-gray-400">
                    {endpoint.path}
                  </td>
                  <td class="px-6 py-4 text-gray-600 dark:text-gray-400">
                    {endpoint.description}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- URL Prefixes Table -->
      <div>
        <h3 class="text-xl font-semibold mb-4 text-gray-900 dark:text-gray-100">
          {t.architectureComparison.domain.prefixesTitle}
        </h3>

        <div class="overflow-x-auto rounded-lg border border-gray-200 dark:border-gray-800">
          <table class="w-full text-sm">
            <thead class="bg-gray-50 dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800">
              <tr>
                <th class="px-6 py-3 text-left font-semibold text-gray-900 dark:text-gray-100">
                  URL Prefix
                </th>
                <th class="px-6 py-3 text-left font-semibold text-gray-900 dark:text-gray-100">
                  Architecture
                </th>
              </tr>
            </thead>
            <tbody>
              {t.architectureComparison.domain.prefixes.map((prefix: any) => (
                <tr class="border-b border-gray-200 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-900/50">
                  <td class="px-6 py-4 font-mono text-xs font-semibold text-purple-600 dark:text-purple-400">
                    {prefix.path}
                  </td>
                  <td class="px-6 py-4 text-gray-600 dark:text-gray-400">
                    {prefix.arch}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Evolution Phases Section -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold mb-6 text-gray-900 dark:text-gray-100">
        {t.architectureComparison.phases.title}
      </h2>

      <p class="text-gray-600 dark:text-gray-400 mb-8 text-lg">
        {t.architectureComparison.phases.description}
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[1, 2, 3, 4].map((phase) => {
          const phaseKey = `phase0${phase}`;
          const phaseData = t.architectureComparison.phases[phaseKey];

          return (
            <div
              class="rounded-lg border border-gray-200 dark:border-gray-800 p-6 hover:shadow-md transition-shadow"
            >
              <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">
                {phaseData.title}
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                {phaseData.description}
              </p>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Charts Section -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold mb-4 text-gray-900 dark:text-gray-100">
        {t.architectureComparison.charts.quadrant.title}
      </h2>

      <p class="text-gray-600 dark:text-gray-400 mb-8 text-lg">
        {t.architectureComparison.charts.quadrant.caption}
      </p>

      <div class="relative w-full bg-white dark:bg-gray-900 rounded-lg border border-gray-200 dark:border-gray-800 p-4 md:p-6">
        <canvas id="quadrantChart" style="max-height: 400px;"></canvas>
      </div>

      <p class="mt-3 text-sm text-gray-600 dark:text-gray-400 italic">
        {t.architectureComparison.charts.quadrant.caption}
      </p>
    </section>

    <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/chartjs-plugin-annotation@3"></script>

    <script define:vars={{ currentLang: lang }}>
      function initQuadrantChart() {
        if (!window.Chart) {
          setTimeout(initQuadrantChart, 100);
          return;
        }

        const canvas = document.getElementById('quadrantChart');
        if (!canvas) return;

        const ctx = canvas.getContext('2d');
        if (!ctx) return;

        const isDark = document.documentElement.classList.contains('dark');
        const textColor = isDark ? '#9ca3af' : '#4b5563';
        const gridColor = isDark ? '#374151' : '#e5e7eb';
        const isEs = currentLang === 'es';

        const xAxisTitle = isEs ? 'Simplicidad' : 'Simplicity';
        const yAxisTitle = isEs ? 'Fragilidad' : 'Fragility';
        const tooltipFiles = isEs ? 'archivos' : 'files';
        const tooltipFragility = isEs ? 'Fragilidad' : 'Fragility';

        const chartData = {
          datasets: [
            {
              label: 'A01',
              data: [{ x: 6, y: 10 }],
              borderColor: '#3b82f6',
              backgroundColor: '#3b82f6',
              pointRadius: 10,
              pointHoverRadius: 12,
              pointBorderWidth: 3,
              pointBorderColor: isDark ? '#111827' : '#ffffff'
            },
            {
              label: 'A02',
              data: [{ x: 10, y: 7 }],
              borderColor: '#a855f7',
              backgroundColor: '#a855f7',
              pointRadius: 10,
              pointHoverRadius: 12,
              pointBorderWidth: 3,
              pointBorderColor: isDark ? '#111827' : '#ffffff'
            },
            {
              label: 'A03',
              data: [{ x: 14, y: 5.5 }],
              borderColor: '#10b981',
              backgroundColor: '#10b981',
              pointRadius: 10,
              pointHoverRadius: 12,
              pointBorderWidth: 3,
              pointBorderColor: isDark ? '#111827' : '#ffffff'
            },
            {
              label: 'A04',
              data: [{ x: 22, y: 2 }],
              borderColor: '#f59e0b',
              backgroundColor: '#f59e0b',
              pointRadius: 10,
              pointHoverRadius: 12,
              pointBorderWidth: 3,
              pointBorderColor: isDark ? '#111827' : '#ffffff'
            }
          ]
        };

        new window.Chart(ctx, {
          type: 'scatter',
          data: chartData,
          options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
              legend: {
                position: 'top',
                labels: {
                  color: textColor,
                  usePointStyle: true,
                  padding: 8,
                  font: { size: 11, weight: '600' },
                  boxWidth: 8,
                  boxHeight: 8
                }
              },
              tooltip: {
                backgroundColor: isDark ? 'rgba(0, 0, 0, 0.8)' : 'rgba(0, 0, 0, 0.9)',
                titleColor: '#fff',
                bodyColor: '#fff',
                borderColor: gridColor,
                borderWidth: 1,
                padding: 10,
                titleFont: { size: 12, weight: 'bold' },
                bodyFont: { size: 11 },
                callbacks: {
                  title: function(context) {
                    return context[0].dataset.label;
                  },
                  label: function(context) {
                    const point = context.raw;
                    return `${point.x} ${tooltipFiles} · ${tooltipFragility} ${point.y}/10`;
                  }
                }
              },
              annotation: {
                annotations: {
                  midlineX: {
                    type: 'line',
                    xMin: 14,
                    xMax: 14,
                    borderColor: gridColor,
                    borderWidth: 2,
                    borderDash: [6, 6]
                  },
                  midlineY: {
                    type: 'line',
                    yMin: 6,
                    yMax: 6,
                    borderColor: gridColor,
                    borderWidth: 2,
                    borderDash: [6, 6]
                  }
                }
              }
            },
            scales: {
              x: {
                title: {
                  display: true,
                  text: xAxisTitle,
                  color: textColor,
                  font: { size: 12, weight: 'bold' }
                },
                min: 0,
                max: 28,
                ticks: {
                  color: textColor,
                  stepSize: 4,
                  font: { size: 10 }
                },
                grid: {
                  color: gridColor,
                  drawBorder: false
                }
              },
              y: {
                title: {
                  display: true,
                  text: yAxisTitle,
                  color: textColor,
                  font: { size: 12, weight: 'bold' }
                },
                min: 0,
                max: 12,
                ticks: {
                  color: textColor,
                  stepSize: 2,
                  font: { size: 10 }
                },
                grid: {
                  color: gridColor,
                  drawBorder: false
                }
              }
            }
          }
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initQuadrantChart);
      } else {
        initQuadrantChart();
      }
    </script>

    <!-- Rankings Section -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold mb-8 text-gray-900 dark:text-gray-100">
        🏆 {t.architectureComparison.rankings.title}
      </h2>

      <div class="overflow-x-auto rounded-lg border border-gray-200 dark:border-gray-800">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800">
            <tr>
              <th class="px-6 py-3 text-left font-semibold text-gray-900 dark:text-gray-100">
                Criterion
              </th>
              <th class="px-6 py-3 text-left font-semibold text-yellow-600 dark:text-yellow-400">
                🥇 Gold
              </th>
              <th class="px-6 py-3 text-left font-semibold text-gray-400">
                🥈 Silver
              </th>
              <th class="px-6 py-3 text-left font-semibold text-orange-600 dark:text-orange-400">
                🥉 Bronze
              </th>
              <th class="px-6 py-3 text-left font-semibold text-red-600 dark:text-red-400">
                ❌ Worst
              </th>
            </tr>
          </thead>
          <tbody>
            {Object.entries(t.architectureComparison.rankings.criteria).map(([key, criterion]: any) => (
              <tr class="border-b border-gray-200 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-900/50">
                <td class="px-6 py-4 font-semibold text-gray-900 dark:text-gray-100">
                  {criterion.label}
                </td>
                <td class="px-6 py-4 text-gray-600 dark:text-gray-400">
                  {criterion.gold}
                </td>
                <td class="px-6 py-4 text-gray-600 dark:text-gray-400">
                  {criterion.silver}
                </td>
                <td class="px-6 py-4 text-gray-600 dark:text-gray-400">
                  {criterion.bronze}
                </td>
                <td class="px-6 py-4 text-gray-600 dark:text-gray-400">
                  {criterion.worst}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- When to Use Each Section -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold mb-8 text-gray-900 dark:text-gray-100">
        ⚡ {t.architectureComparison.useCases.title}
      </h2>

      <p class="text-gray-600 dark:text-gray-400 mb-8 text-lg">
        {t.architectureComparison.useCases.description}
      </p>

      <div class="space-y-4">
        {t.architectureComparison.useCases.scenarios.map((scenario: any) => (
          <div
            class="flex flex-col md:flex-row md:items-center gap-4 rounded-lg border border-gray-200 dark:border-gray-800 p-6 hover:shadow-md transition-shadow"
          >
            <div class="md:flex-1">
              <p class="font-semibold text-gray-900 dark:text-gray-100">
                {scenario.condition}
              </p>
            </div>
            <div class="md:flex-1">
              <p class="text-blue-600 dark:text-blue-400 font-medium">
                → {scenario.recommendation}
              </p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Key Conclusions Section -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold mb-8 text-gray-900 dark:text-gray-100">
        💡 {t.architectureComparison.conclusions.title}
      </h2>

      <div class="space-y-6">
        {["a01", "a02", "a03", "a04"].map((archId) => {
          const conclusion = t.architectureComparison.conclusions[archId];
          const gradients = {
            a01: "border-blue-200 dark:border-blue-900 bg-blue-50 dark:bg-blue-950/30",
            a02: "border-purple-200 dark:border-purple-900 bg-purple-50 dark:bg-purple-950/30",
            a03: "border-emerald-200 dark:border-emerald-900 bg-emerald-50 dark:bg-emerald-950/30",
            a04: "border-amber-200 dark:border-amber-900 bg-amber-50 dark:bg-amber-950/30"
          };
          const textColors = {
            a01: "text-blue-900 dark:text-blue-200",
            a02: "text-purple-900 dark:text-purple-200",
            a03: "text-emerald-900 dark:text-emerald-200",
            a04: "text-amber-900 dark:text-amber-200"
          };

          return (
            <div class={`rounded-lg border p-6 ${gradients[archId]}`}>
              <h3 class={`font-bold text-lg mb-2 ${textColors[archId]}`}>
                {conclusion.title}
              </h3>
              <p class={textColors[archId]}>
                {conclusion.description}
              </p>
            </div>
          );
        })}
      </div>
    </section>

    <!-- CTA Section -->
    <section>
      <h2 class="text-3xl font-bold mb-8 text-center text-gray-900 dark:text-gray-100">
        {t.architectureComparison.cta.title}
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        {["a01", "a02", "a03", "a04"].map((archId) => {
          const arch = t.architectureComparison.architectures[archId];
          const gradients = {
            a01: "from-blue-500/10 to-blue-400/5",
            a02: "from-purple-500/10 to-purple-400/5",
            a03: "from-emerald-500/10 to-emerald-400/5",
            a04: "from-amber-500/10 to-amber-400/5"
          };
          const textColors = {
            a01: "text-blue-600 dark:text-blue-400",
            a02: "text-purple-600 dark:text-purple-400",
            a03: "text-emerald-600 dark:text-emerald-400",
            a04: "text-amber-600 dark:text-amber-400"
          };
          return (
            <a
              href={`${langPrefix}/projects/architecture-comparison/${archId}/`}
              class={`group arch-gradient flex flex-col justify-between rounded-xl border border-gray-200 dark:border-gray-800 p-6 bg-gradient-to-br ${gradients[archId]} hover:shadow-lg hover:-translate-y-1 transition-all`}
            >
              <div>
                <h3 class="text-lg font-bold mb-2 text-gray-900 dark:text-gray-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">{arch.name}</h3>
                <p class="text-sm text-gray-500 dark:text-gray-500">{arch.pattern}</p>
              </div>
              <span class={`inline-flex items-center gap-2 text-sm font-medium ${textColors[archId]}`}>
                {arch.link}
                <svg
                  class="w-4 h-4 group-hover:translate-x-1 transition-transform"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </a>
          );
        })}
      </div>

      <div class="text-center">
        <a
          href={`${langPrefix}/projects/architecture-comparison/conclusions/`}
          class="inline-flex items-center gap-2 px-8 py-4 bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 font-semibold rounded-xl hover:bg-gray-800 dark:hover:bg-gray-200 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
          </svg>
          View Complete Rankings
        </a>
      </div>
    </section>
  </article>
</BaseLayout>
