---
import WebProjectLayout from "../../components/WebProjectLayout.astro";
import TextSection from "../../components/TextSection.astro";
import ImageRightSection from "../../components/ImageRightSection.astro";
import ImageLeftSection from "../../components/ImageLeftSection.astro";
import CodeBlock from "../../components/CodeBlock.astro";

import { createHighlighter } from "shiki";

import { getLangFromUrl } from "../../i18n/getLang";
import { getTranslations } from "../../i18n";

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);

const highlighter = await createHighlighter({
  themes: ["github-light", "github-dark"],
  langs: ["typescript", "astro"]
});

const highlight = (code: string, language: string) => ({
  light: highlighter.codeToHtml(code, {
    lang: language,
    theme: "github-light"
  }),
  dark: highlighter.codeToHtml(code, {
    lang: language,
    theme: "github-dark"
  })
});

const codeSection = t.puraVida.sections.find((s) => s.type === "code");
const highlightedFiles =
  codeSection?.files.map((f: any) => ({
    ...f,
    highlightedLight: highlight(f.code, f.language).light,
    highlightedDark: highlight(f.code, f.language).dark
  })) || [];

const sectionsForMenu = t.puraVida.sections.map((s: any) => ({
  id: s.id,
  title: s.title
}));
---

<WebProjectLayout sections={sectionsForMenu}>
  <!-- Hero Header -->
  <header class="mb-14">
    <div
      class="rounded-xl p-6
        bg-gradient-to-br
        from-white/80 via-white/50 to-transparent
        dark:from-gray-900/80 dark:via-gray-900/50 dark:to-transparent
        backdrop-blur-md"
    >
      <p class="text-sm text-gray-500 mb-2">
        Web Project
      </p>

      <h1 class="text-3xl md:text-4xl font-bold mb-4">
        {t.puraVida.title}
      </h1>

      <p class="text-lg text-gray-600 dark:text-gray-400">
        {t.puraVida.subtitle}
      </p>
    </div>
  </header>

  <!-- Render sections dynamically -->
  {t.puraVida.sections.map((section: any) => {
    if (section.type === "text") {
      return <TextSection id={section.id} title={section.title} paragraphs={section.paragraphs} />;
    }
    if (section.type === "image-right") {
      return (
        <ImageRightSection
          id={section.id}
          title={section.title}
          text={section.text}
          image={section.image}
          imageAlt={section.imageAlt}
        />
      );
    }
    if (section.type === "image-left") {
      return (
        <ImageLeftSection
          id={section.id}
          title={section.title}
          text={section.text}
          image={section.image}
          imageAlt={section.imageAlt}
        />
      );
    }
    if (section.type === "code") {
      return (
        <CodeBlock
          id={section.id}
          title={section.title}
          files={highlightedFiles}
        />
      );
    }
  })}
</WebProjectLayout>
