---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BackLink from "../../components/BackLink.astro";

import { getLangFromUrl } from "../../i18n/getLang";
import { getTranslations } from "../../i18n";

const lang = getLangFromUrl(Astro.url);
const langPrefix = lang === "es" ? "/es" : "";
const t = getTranslations(lang);
---

<BaseLayout>
    <article class="max-w-3xl mx-auto">
        <BackLink href="/projects" label={t.underConstruction.back} />

        <header class="mb-14">
            <div
                class="rounded-xl p-6
                    bg-gradient-to-br
                    from-white/80 via-white/50 to-transparent
                    dark:from-gray-900/80 dark:via-gray-900/50 dark:to-transparent
                    backdrop-blur-md"
            >
                <p class="text-sm text-gray-500 mb-2">
                    {t.underConstruction.header.label}
                </p>

                <h1 class="text-3xl md:text-4xl font-bold mb-4">
                    {t.projects.items["pura-vida"].title}
                </h1>

                <p class="text-lg text-gray-600 dark:text-gray-400">
                    {t.underConstruction.header.description}
                </p>
            </div>
        </header>

        <section class="mb-16">
            <div class="flex justify-center mb-10">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="w-20 h-20 text-blue-500/60"
                >
                    <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
                </svg>
            </div>

            <div class="text-center mb-10 pl-6 border-l-2 border-blue-500/40">
                <p class="text-lg text-gray-700 dark:text-gray-300 leading-relaxed">
                    {t.underConstruction.message}
                </p>
            </div>

            <div class="flex justify-center">
                <a
                    href={`${langPrefix}/projects`}
                    class="inline-flex items-center gap-2 px-6 py-3 rounded-lg
                        bg-gradient-to-r from-blue-500/10 to-purple-500/10
                        dark:from-blue-500/20 dark:to-purple-500/20
                        border border-blue-500/30
                        text-blue-600 dark:text-blue-400
                        font-medium
                        hover:from-blue-500/20 hover:to-purple-500/20
                        dark:hover:from-blue-500/30 dark:hover:to-purple-500/30
                        hover:border-blue-500/50
                        transition-all duration-300
                        hover:-translate-y-0.5 hover:shadow-md"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="w-4 h-4"
                    >
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                        <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                    {t.underConstruction.button}
                </a>
            </div>
        </section>
    </article>
</BaseLayout>
