---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MetricCard from "../../components/MetricCard.astro";
import BackLink from "../../components/BackLink.astro";

import { getLangFromUrl } from "../../i18n/getLang";
import { getTranslations } from "../../i18n";

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
---

<BaseLayout>
    <article class="max-w-3xl mx-auto">
        <BackLink href="/projects" label={t.apiBenchmark.back} />

        <header class="mb-14">
            <p class="text-sm text-gray-500 mb-2">{t.apiBenchmark.header.label}</p>

            <h1 class="text-3xl md:text-4xl font-bold mb-4">
                {t.apiBenchmark.header.title}
            </h1>

            <p class="text-lg text-gray-600 dark:text-gray-400">
                {t.apiBenchmark.header.description}
            </p>
        </header>

        <section class="mb-16">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-10">
                <div
                    class="border border-gray-200 dark:border-gray-800 rounded-lg p-5 bg-white/95 dark:bg-gray-900/95 backdrop-blur-sm"
                >
                    <p class="font-semibold mb-1">{t.apiBenchmark.highlights.implementations.title}</p>
                    <p class="text-sm text-gray-500 dark:text-gray-400">
                        {t.apiBenchmark.highlights.implementations.description}
                    </p>
                </div>

                <div
                    class="border border-gray-200 dark:border-gray-800 rounded-lg p-5 bg-white/95 dark:bg-gray-900/95 backdrop-blur-sm"
                >
                    <p class="font-semibold mb-1">{t.apiBenchmark.highlights.domain.title}</p>
                    <p class="text-sm text-gray-500 dark:text-gray-400">
                        {t.apiBenchmark.highlights.domain.description}
                    </p>
                </div>

                <div
                    class="border border-gray-200 dark:border-gray-800 rounded-lg p-5 bg-white/95 dark:bg-gray-900/95 backdrop-blur-sm"
                >
                    <p class="font-semibold mb-1">{t.apiBenchmark.highlights.focus.title}</p>
                    <p class="text-sm text-gray-500 dark:text-gray-400">
                        {t.apiBenchmark.highlights.focus.description}
                    </p>
                </div>
            </div>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.apiBenchmark.intro.p1}
            </p>

            <p class="text-gray-600 dark:text-gray-400">
                {t.apiBenchmark.intro.p2}
            </p>
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">🧩 {t.apiBenchmark.domain_section.title}</h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.apiBenchmark.domain_section.p1}
            </p>

            <ul
                class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
            >
                <li>{t.apiBenchmark.domain_section.items[0]}</li>
                <li>{t.apiBenchmark.domain_section.items[1]}</li>
                <li>{t.apiBenchmark.domain_section.items[2]}</li>
                <li>{t.apiBenchmark.domain_section.items[3]}</li>
            </ul>
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">🗂️ {t.apiBenchmark.entity_section.title}</h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.apiBenchmark.entity_section.description}
            </p>

            <div
                class="bg-gray-100 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-lg p-5 font-mono text-sm mb-6"
            >
                {t.apiBenchmark.entity_section.fields}
            </div>
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">
                ⚙️ {t.apiBenchmark.implementations_section.title}
            </h2>

            <ul class="space-y-4 text-gray-600 dark:text-gray-400">
                <li>
                    <strong>PHP</strong> — {t.apiBenchmark.implementations_section.plain_php}
                </li>

                <li>
                    <strong>Laravel</strong> — {t.apiBenchmark.implementations_section.laravel}
                </li>

                <li>
                    <strong>Symfony</strong> — {t.apiBenchmark.implementations_section.symfony}
                </li>
            </ul>
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">📊 {t.apiBenchmark.criteria_section.title}</h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.apiBenchmark.criteria_section.intro}
            </p>

            <ul
                class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
            >
                <li>{t.apiBenchmark.criteria_section.items[0]}</li>
                <li>{t.apiBenchmark.criteria_section.items[1]}</li>
                <li>{t.apiBenchmark.criteria_section.items[2]}</li>
                <li>{t.apiBenchmark.criteria_section.items[3]}</li>
            </ul>
        </section>

        <section>
            <h2 class="text-xl font-semibold mb-6">🎯 {t.apiBenchmark.goal_section.title}</h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.apiBenchmark.goal_section.p1}
            </p>

            <p class="text-gray-600 dark:text-gray-400">
                {t.apiBenchmark.goal_section.p2}
            </p>
        </section>
    </article>
</BaseLayout>
