---
import BaseLayout from "../layouts/BaseLayout.astro";
import BackLink from "../components/BackLink.astro";
---

<BaseLayout>

<section>

<BackLink href="/" label="Back to home" />

  <!-- Header -->
  <header class="mb-16 max-w-2xl">
    <h1 class="text-3xl md:text-4xl font-bold mb-4">
      Contact
    </h1>

    <p class="text-gray-600 dark:text-gray-400">
      Feel free to reach out if you'd like to discuss backend architecture,
      software design or potential collaborations.
    </p>
  </header>

  <!-- Contact Cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

    <!-- GitHub -->
    <a
      href="https://github.com/MMoza"
      target="_blank"
      rel="noopener noreferrer"
      class="group border border-gray-200 dark:border-gray-800 rounded-xl p-6 bg-white dark:bg-gray-900 transition-all duration-300 hover:shadow-md hover:-translate-y-1 flex flex-col"
    >

      <div class="flex items-center gap-4 mb-4">

        <svg xmlns="http://www.w3.org/2000/svg"
          class="w-7 h-7 text-gray-700 dark:text-gray-300 group-hover:text-blue-600 transition-colors"
          fill="currentColor"
          viewBox="0 0 24 24">

          <path d="M12 0C5.37 0 0 5.37 0 12a12 12 0 008.21 11.38c.6.11.82-.26.82-.58v-2.02c-3.34.73-4.04-1.61-4.04-1.61-.55-1.38-1.33-1.75-1.33-1.75-1.09-.75.08-.74.08-.74 1.2.08 1.84 1.23 1.84 1.23 1.07 1.84 2.8 1.31 3.48 1 .11-.77.42-1.31.76-1.61-2.66-.3-5.46-1.33-5.46-5.93 0-1.31.47-2.38 1.23-3.22-.12-.3-.53-1.52.12-3.18 0 0 1-.32 3.3 1.23a11.4 11.4 0 016 0C17.3 3.6 18.3 3.92 18.3 3.92c.65 1.66.24 2.88.12 3.18.76.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.62-5.47 5.92.43.37.82 1.1.82 2.22v3.29c0 .32.21.7.83.58A12 12 0 0024 12c0-6.63-5.37-12-12-12z"/>

        </svg>

        <h2 class="text-lg font-semibold">
          GitHub
        </h2>

      </div>

      <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
        Explore my projects, experiments and backend architecture explorations.
      </p>

      <span class="text-sm text-blue-600 mt-auto">
        github.com/MMoza
      </span>

    </a>


    <!-- LinkedIn -->
    <a
      href="https://www.linkedin.com/in/miguel-angel-moza-barquilla-040b63256/"
      target="_blank"
      rel="noopener noreferrer"
      class="group border border-gray-200 dark:border-gray-800 rounded-xl p-6 bg-white dark:bg-gray-900 transition-all duration-300 hover:shadow-md hover:-translate-y-1 flex flex-col"
    >

      <div class="flex items-center gap-4 mb-4">

        <svg xmlns="http://www.w3.org/2000/svg"
          class="w-7 h-7 text-gray-700 dark:text-gray-300 group-hover:text-blue-600 transition-colors"
          fill="currentColor"
          viewBox="0 0 24 24">

          <path d="M20.45 20.45h-3.55v-5.6c0-1.34-.03-3.06-1.86-3.06-1.86 0-2.15 1.45-2.15 2.96v5.7H9.33V9h3.41v1.56h.05c.48-.9 1.63-1.85 3.36-1.85 3.59 0 4.25 2.36 4.25 5.43v6.31zM5.34 7.43a2.06 2.06 0 110-4.12 2.06 2.06 0 010 4.12zM7.12 20.45H3.56V9h3.56v11.45z"/>

        </svg>

        <h2 class="text-lg font-semibold">
          LinkedIn
        </h2>

      </div>

      <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
        Connect with me professionally and see my full career background.
      </p>

      <span class="text-sm text-blue-600 mt-auto">
        linkedin.com/in/miguel-angel-moza-barquilla
      </span>

    </a>


    <!-- Email -->
    <a
      href="mailto:miguelangelmozabarquilla@gmail.com"
      class="group border border-gray-200 dark:border-gray-800 rounded-xl p-6 bg-white dark:bg-gray-900 transition-all duration-300 hover:shadow-md hover:-translate-y-1 flex flex-col"
    >

      <div class="flex items-center gap-4 mb-4">

        <svg xmlns="http://www.w3.org/2000/svg"
          class="w-7 h-7 text-gray-700 dark:text-gray-300 group-hover:text-blue-600 transition-colors"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24">

          <path d="M22 6l-10 7L2 6"/>
          <rect x="2" y="4" width="20" height="16" rx="2"/>

        </svg>

        <h2 class="text-lg font-semibold">
          Email
        </h2>

      </div>

      <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
        The best way to contact me for professional opportunities or technical discussions.
      </p>

      <span class="text-sm text-blue-600 mt-auto">
        miguelangelmozabarquilla@gmail.com
      </span>

    </a>

  </div>

</section>

</BaseLayout>