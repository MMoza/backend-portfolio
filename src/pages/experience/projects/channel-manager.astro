---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import MetricCard from "../../../components/MetricCard.astro";
import BackLink from "../../../components/BackLink.astro";
import { getLangFromUrl } from "../../../i18n/getLang";
import { getTranslations } from "../../../i18n/index";

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
---

<BaseLayout>
    <article class="max-w-3xl mx-auto">
        <BackLink
            href="/experience/backend-developer"
            label={t.channelManager.back}
        />

        <header class="mb-14">
            <h1 class="text-3xl md:text-4xl font-bold mb-4">
                {t.channelManager.header.title}
            </h1>

            <p class="text-gray-600 dark:text-gray-400">
                {t.channelManager.header.description}
            </p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-10">
            {
                t.channelManager.metrics.map((metric) => (
                    <MetricCard value={metric.value} label={metric.label} />
                ))
            }
        </div>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">{t.channelManager.context.title}</h2>

            {
                t.channelManager.context.paragraphs.map((paragraph) => (
                    <p class="text-gray-600 dark:text-gray-400 mb-4">
                        {paragraph}
                    </p>
                ))
            }
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">
                {t.channelManager.distributions.title}
            </h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.channelManager.distributions.intro}
            </p>

            <ul
                class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
            >
                {
                    t.channelManager.distributions.platforms.map((platform) => (
                        <li>{platform}</li>
                    ))
                }
            </ul>
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">{t.channelManager.apiEvolution.title}</h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {t.channelManager.apiEvolution.intro}
            </p>

            <ul
                class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
            >
                {
                    t.channelManager.apiEvolution.items.map((item) => (
                        <li>{item}</li>
                    ))
                }
            </ul>
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">
                {t.channelManager.octo.title}
            </h2>

            {
                t.channelManager.octo.paragraphs.map((paragraph) => (
                    <p class="text-gray-600 dark:text-gray-400 mb-4">
                        {paragraph}
                    </p>
                ))
            }
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">
                {t.channelManager.reverseChannel.title}
            </h2>

            {
                t.channelManager.reverseChannel.paragraphs.map((paragraph) => (
                    <p class="text-gray-600 dark:text-gray-400 mb-4">
                        {paragraph}
                    </p>
                ))
            }
        </section>
    </article>
</BaseLayout>
