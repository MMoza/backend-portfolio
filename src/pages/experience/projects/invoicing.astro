---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import MetricCard from "../../../components/MetricCard.astro";
import BackLink from "../../../components/BackLink.astro";
import { getLangFromUrl } from "../../../i18n/getLang";
import { getTranslations } from "../../../i18n/index";

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
---

<BaseLayout>
    <article class="max-w-3xl mx-auto">
        <BackLink
            href="/experience/backend-developer"
            label={t.invoicing.back}
        />

        <!-- HEADER -->

        <header class="mb-14">
            <h1 class="text-3xl font-bold mb-4">
                {t.invoicing.header.title}
            </h1>

            <p class="text-gray-600 dark:text-gray-400">
                {t.invoicing.header.description}
            </p>
        </header>

        <!-- METRICS -->

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-12">
            {
                t.invoicing.metrics.map((metric) => (
                    <MetricCard value={metric.value} label={metric.label} />
                ))
            }
        </div>

        <!-- CONTEXT -->

        <section class="mb-12">
            <h2 class="text-xl font-semibold mb-4">
                {t.invoicing.context.title}
            </h2>

            {
                t.invoicing.context.paragraphs.map((paragraph) => (
                    <p class="text-gray-600 dark:text-gray-400 mb-6">
                        {paragraph}
                    </p>
                ))
            }
        </section>

        <!-- DOMAIN UNIFICATION -->

        <section class="mb-12">
            <h2 class="text-xl font-semibold mb-4">
                {t.invoicing.domain.title}
            </h2>

            {
                t.invoicing.domain.paragraphs.map((paragraph) => (
                    <p class="text-gray-600 dark:text-gray-400 mb-6">
                        {paragraph}
                    </p>
                ))
            }
        </section>

        <!-- INTEGRATION ARCHITECTURE -->

        <section class="mb-12">
            <h2 class="text-xl font-semibold mb-4">
                {t.invoicing.architecture.title}
            </h2>

            {
                t.invoicing.architecture.paragraphs.map((paragraph) => (
                    <p class="text-gray-600 dark:text-gray-400 mb-6">
                        {paragraph}
                    </p>
                ))
            }
        </section>

        <!-- CURRENT INTEGRATIONS -->

        <section class="mb-12">
            <h2 class="text-xl font-semibold mb-4">
                {t.invoicing.integrations.title}
            </h2>

            <ul class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6">
                {
                    t.invoicing.integrations.items.map((item) => (
                        <li>
                            <strong>{item.name}</strong> {item.description}
                        </li>
                    ))
                }
            </ul>
        </section>

        <!-- EXTENSIBILITY -->

        <section>
            <h2 class="text-xl font-semibold mb-4">
                {t.invoicing.extensibility.title}
            </h2>

            {
                t.invoicing.extensibility.paragraphs.map((paragraph) => (
                    <p class="text-gray-600 dark:text-gray-400 mb-6">
                        {paragraph}
                    </p>
                ))
            }
        </section>
    </article>
</BaseLayout>
