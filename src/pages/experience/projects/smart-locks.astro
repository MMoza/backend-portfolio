---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import MetricCard from "../../../components/MetricCard.astro";
import BackLink from "../../../components/BackLink.astro";
import { getLangFromUrl } from "../../../i18n/getLang";
import { getTranslations } from "../../../i18n/index";

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
const smartLocks = t.smartLocks;
---

<BaseLayout>
    <article class="max-w-3xl mx-auto">
        <BackLink
            href="/experience/backend-developer"
            label={smartLocks.backLink.label}
        />

        <header class="mb-14">
            <h1 class="text-3xl md:text-4xl font-bold mb-4">
                {smartLocks.header.title}
            </h1>

            <p class="text-gray-600 dark:text-gray-400">
                {smartLocks.header.description}
            </p>
        </header>

        <!-- METRICS -->

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-10">
            <MetricCard
                value={smartLocks.metrics.providers.value}
                label={smartLocks.metrics.providers.label}
            />

            <MetricCard
                value={smartLocks.metrics.locks.value}
                label={smartLocks.metrics.locks.label}
            />

            <MetricCard
                value={smartLocks.metrics.accommodations.value}
                label={smartLocks.metrics.accommodations.label}
            />
        </div>

        <!-- ARCHITECTURE -->

        <section class="mb-12">
            <h2 class="text-xl font-semibold mb-4">
                {smartLocks.architecture.title}
            </h2>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {smartLocks.architecture.p1}
            </p>

            <p class="text-gray-600 dark:text-gray-400 mb-4">
                {smartLocks.architecture.p2.split("Key")[0]}
                <strong>Key</strong>
                {smartLocks.architecture.p2.split("Key")[1]}
            </p>

            <p class="text-gray-600 dark:text-gray-400">
                {smartLocks.architecture.p3}
            </p>
        </section>

        <!-- WORKFLOW -->

        <section class="mb-12">
            <h2 class="text-xl font-semibold mb-4">
                {smartLocks.workflow.title}
            </h2>

            <p class="text-gray-600 dark:text-gray-400 mb-6">
                {smartLocks.workflow.intro}
            </p>

            <ul
                class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
            >
                <li>
                    <strong>
                        {smartLocks.workflow.strategies.directLockMapping.title}:
                    </strong>
                    {smartLocks.workflow.strategies.directLockMapping.description}
                </li>

                <li>
                    <strong>
                        {smartLocks.workflow.strategies.roomSynchronization.title}:
                    </strong>
                    {smartLocks.workflow.strategies.roomSynchronization.description}
                </li>
            </ul>
        </section>

        <!-- TECHNICAL NOTES -->

        <section>
            <h2 class="text-xl font-semibold mb-4">
                {smartLocks.technicalHighlights.title}
            </h2>

            <ul
                class="space-y-2 text-gray-600 dark:text-gray-400 list-disc pl-6"
            >
                {smartLocks.technicalHighlights.items.map((item) => (
                    <li>{item}</li>
                ))}
            </ul>
        </section>
    </article>
</BaseLayout>