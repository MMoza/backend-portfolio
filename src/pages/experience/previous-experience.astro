---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BackLink from "../../components/BackLink.astro";
import { getLangFromUrl } from "../../i18n/getLang";
import { getTranslations } from "../../i18n/index";

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
---

<BaseLayout>
    <article class="max-w-3xl mx-auto">
        <BackLink href="/experience" label={t.previousExperience.back} />

        <header class="mb-14">
            <h1 class="text-3xl md:text-4xl font-bold mb-4">
                {t.previousExperience.header.title}
            </h1>

            <p class="text-gray-600 dark:text-gray-400">
                {t.previousExperience.header.introBefore}
                <strong>{t.previousExperience.header.introStrong}</strong>
                {t.previousExperience.header.introAfter}
            </p>
        </header>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-8">{t.previousExperience.timeline.title}</h2>

            <div
                class="relative border-l border-gray-200 dark:border-gray-800 pl-6 space-y-10"
            >
                {t.previousExperience.timeline.items.map((item: any) => (
                    <div class="relative">
                        <span
                            class={`absolute -left-[30px] top-1.5 w-3 h-3 rounded-full ${
                                item.highlight ? 'bg-white shadow-md shadow-blue-500/40' : 'bg-blue-600 shadow-blue-500/40'
                            }`}
                        ></span>

                        <p class="text-sm text-gray-500 mb-1">{item.period}</p>

                        <h3 class={`font-semibold ${item.highlight ? 'text-blue-600' : ''}`}>
                            {item.title}
                        </h3>

                        <p class="text-gray-600 dark:text-gray-400 text-sm">
                            {item.description}
                        </p>
                    </div>
                ))}
            </div>
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">{t.previousExperience.hospitality.title}</h2>

            {t.previousExperience.hospitality.paragraphs.map((paragraph: string) => (
                <p class="text-gray-600 dark:text-gray-400 mb-4">
                    {paragraph}
                </p>
            ))}
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">
                {t.previousExperience.industrial.title}
            </h2>

            {t.previousExperience.industrial.paragraphs.map((paragraph: string) => (
                <p class="text-gray-600 dark:text-gray-400 mb-4">
                    {paragraph}
                </p>
            ))}
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">{t.previousExperience.discovering.title}</h2>

            {t.previousExperience.discovering.paragraphs.map((paragraph: string) => (
                <p class="text-gray-600 dark:text-gray-400 mb-4">
                    {paragraph}
                </p>
            ))}
        </section>

        <section>
            <h2 class="text-xl font-semibold mb-6">{t.previousExperience.skills.title}</h2>

            <div class="flex flex-wrap gap-2">
                {t.previousExperience.skills.items.map((skill: string) => (
                    <span
                        class="px-3 py-1 rounded-md bg-gray-100 dark:bg-gray-800 text-sm transition hover:bg-blue-100 dark:hover:bg-gray-700"
                    >
                        {skill}
                    </span>
                ))}
            </div>
        </section>
    </article>
</BaseLayout>
</BaseLayout>