---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BackLink from "../../components/BackLink.astro";
import { getLangFromUrl } from "../../i18n/getLang";
import { getTranslations } from "../../i18n/index";

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
---

<BaseLayout>
    <article class="max-w-3xl mx-auto">
        <BackLink href="/experience" label={t.previousExperience.back} />

        <header class="mb-14">
            <h1 class="text-3xl md:text-4xl font-bold mb-4">
                {t.previousExperience.header.title}
            </h1>

            <p class="text-gray-600 dark:text-gray-400">
                {t.previousExperience.header.introBefore}
                <strong>{t.previousExperience.header.introStrong}</strong>
                {t.previousExperience.header.introAfter}
            </p>
        </header>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-8">
                {t.previousExperience.timeline.title}
            </h2>

            <div class="relative max-w-3xl mx-auto">

                <!-- timeline line -->
                <div class="absolute left-[6px] md:left-1/2 top-0 bottom-0 w-px bg-gray-200 dark:bg-gray-800"></div>

                <div class="space-y-10">

                    {t.previousExperience.timeline.items.map((item: any) => (
                        <div
                            class={`relative flex group ${
                            item.highlight ? "md:justify-start" : "md:justify-end"
                            }`}
                        >

                            <div class={`pl-10 md:w-1/2 ${item.highlight ? "md:pr-8 md:pl-0" : "md:pl-8"}`}>

                            <!-- timeline dot -->
                            <span
                                class={`absolute top-6 w-3 h-3 rounded-full transition-transform duration-200 group-hover:scale-110
                                ${
                                    item.highlight
                                    ? "left-[0px] md:left-[calc(50%-6px)] bg-blue-400 ring-4 ring-blue-400/20"
                                    : "left-[0px] md:left-[calc(50%-6px)] bg-blue-600 shadow-md shadow-blue-500/30"
                                }
                                `}
                            ></span>

                            <!-- glow connector -->
                            <div
                                class={`absolute top-[29px] h-px w-6
                                bg-gradient-to-r from-blue-500/40 to-transparent
                                opacity-40 group-hover:opacity-80
                                transition-opacity duration-300
                                ${
                                    item.highlight
                                    ? "left-[6px] md:left-[calc(50%-6px)] md:-translate-x-full"
                                    : "left-[6px] md:left-[calc(50%+6px)]"
                                }
                                `}
                            ></div>

                            <!-- timeline card -->
                            <div
                                class="border border-gray-200 dark:border-gray-800 rounded-xl p-5
                                    bg-gradient-to-br from-blue-500/[0.04] via-white/60 to-transparent
                                    dark:from-blue-400/[0.05] dark:via-gray-900/60 dark:to-transparent
                                    backdrop-blur-sm
                                    hover:from-blue-500/[0.10] hover:via-white hover:to-transparent
                                    dark:hover:from-blue-400/[0.12] dark:hover:via-gray-900 dark:hover:to-transparent
                                    hover:shadow-md hover:shadow-blue-500/10
                                    transition-all duration-300"
                            >

                                <p class="text-sm text-gray-500 mb-1">
                                    {item.period}
                                </p>

                                <h3 class={`font-semibold ${item.highlight ? "text-blue-600 dark:text-blue-400" : ""}`}>
                                    {item.title}
                                </h3>

                                {item.site && (
                                <p class="text-sm text-gray-500 dark:text-gray-400 italic mb-2">
                                    {item.site}
                                </p>
                                )}

                                <p class="text-gray-600 dark:text-gray-400 text-sm">
                                {item.description}
                                </p>

                            </div>

                            </div>
                        </div>
                        ))}
                </div>
            </div>
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">{t.previousExperience.hospitality.title}</h2>

            {t.previousExperience.hospitality.paragraphs.map((paragraph: string) => (
                <p class="text-gray-600 dark:text-gray-400 mb-4">
                    {paragraph}
                </p>
            ))}
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">
                {t.previousExperience.industrial.title}
            </h2>

            {t.previousExperience.industrial.paragraphs.map((paragraph: string) => (
                <p class="text-gray-600 dark:text-gray-400 mb-4">
                    {paragraph}
                </p>
            ))}
        </section>

        <section class="mb-16">
            <h2 class="text-xl font-semibold mb-6">{t.previousExperience.discovering.title}</h2>

            {t.previousExperience.discovering.paragraphs.map((paragraph: string) => (
                <p class="text-gray-600 dark:text-gray-400 mb-4">
                    {paragraph}
                </p>
            ))}
        </section>

        <section>
            <h2 class="text-xl font-semibold mb-6">{t.previousExperience.skills.title}</h2>

            <div class="flex flex-wrap gap-2">
                {t.previousExperience.skills.items.map((skill: string) => (
                    <span
                        class="px-3 py-1 rounded-md bg-gray-100 dark:bg-gray-800 text-sm transition hover:bg-blue-100 dark:hover:bg-gray-700"
                    >
                        {skill}
                    </span>
                ))}
            </div>
        </section>
    </article>
</BaseLayout>

<style>
    timeline-dot {
        transition: transform .2s ease;
    }

    timeline-dot:hover {
        transform: scale(1.15);
    }
</style>