---
import ThemeToggle from "./ThemeToggle.astro";
import LanguageToggle from "./LanguageToggle.astro";

import { getLangFromUrl } from "../i18n/getLang";
import { getTranslations } from "../i18n";

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);

const currentPath = Astro.url.pathname;

const langPrefix = lang === "es" ? "/es" : "";

const linkClass = (path: string) => {
    const base =
        "relative pb-1 transition-colors duration-200 hover:text-blue-600 after:absolute after:left-0 after:-bottom-0.5 after:h-0.5 after:w-full after:bg-blue-600 after:origin-left after:scale-x-0 after:transition-transform after:duration-200 hover:after:scale-x-100";

    const active = "text-blue-600 font-medium after:scale-x-100";
    const inactive = "text-gray-700 dark:text-gray-300";

    return `${base} ${currentPath.startsWith(langPrefix + path) ? active : inactive}`;
};
---

<header
    id="site-header"
    class="sticky top-0 z-50 backdrop-blur bg-white/70 dark:bg-gray-950/70 border-b border-gray-200 dark:border-gray-800 transition-shadow duration-300"
>
    <!-- Accent gradient -->
    <div
        class="absolute inset-x-0 top-0 h-[1px] bg-gradient-to-r from-transparent via-blue-500/60 to-transparent"
    >
    </div>

    <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <!-- Brand -->
        <a
            href={`${langPrefix}/`}
            class="font-semibold text-lg whitespace-nowrap transition-colors duration-200 hover:text-blue-600"
        >
            <span class="hidden sm:inline">Miguel Ángel Moza Barquilla</span>
            <span class="sm:hidden">Miguel Ángel</span>
        </a>

        <!-- Desktop Navigation -->
        <nav class="hidden md:flex items-center gap-6 text-sm">
            <a href={`${langPrefix}/projects`} class={linkClass("/projects")}>
                {t.header.nav.projects}
            </a>

            <a href={`${langPrefix}/experience`} class={linkClass("/experience")}>
                {t.header.nav.experience}
            </a>

            <a href={`${langPrefix}/contact`} class={linkClass("/contact")}>
                {t.header.nav.contact}
            </a>

            <a href={`${langPrefix}/about`} class={linkClass("/about")}>
                {t.header.nav.about}
            </a>

            <!-- Settings / Toggles -->
            <div class="flex items-center gap-2 ml-2">
                <LanguageToggle />
                <ThemeToggle />
            </div>
        </nav>

        <!-- Mobile Menu Button -->
        <button
            id="menu-toggle"
            class="md:hidden p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-6 h-6"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
        </button>
    </div>

    <!-- Mobile Navigation -->
    <div
        id="mobile-menu"
        class="hidden md:hidden border-t border-gray-200 dark:border-gray-800"
    >
        <nav class="max-w-5xl mx-auto px-6 py-4 flex flex-col gap-4 text-sm">
            <a href={`${langPrefix}/projects`} class={linkClass("/projects")}>
                {t.header.nav.projects}
            </a>

            <a href={`${langPrefix}/experience`} class={linkClass("/experience")}>
                {t.header.nav.experience}
            </a>

            <a href={`${langPrefix}/contact`} class={linkClass("/contact")}>
                {t.header.nav.contact}
            </a>

            <a href={`${langPrefix}/about`} class={linkClass("/about")}>
                {t.header.nav.about}
            </a>

            <div class="pt-2 flex flex-col items-start gap-4">
            <LanguageToggle />
            <ThemeToggle />
            </div>
        </nav>
    </div>

    <script>
        const button = document.getElementById("menu-toggle");
        const menu = document.getElementById("mobile-menu");
        const header = document.getElementById("site-header");

        button?.addEventListener("click", () => {
            menu?.classList.toggle("hidden");
        });

        // Shadow on scroll
        const handleScroll = () => {
            if (window.scrollY > 10) {
                header?.classList.add("shadow-md");
            } else {
                header?.classList.remove("shadow-md");
            }
        };

        window.addEventListener("scroll", handleScroll);
    </script>
</header>
