---
const { sections } = Astro.props;
---

<nav class="flex flex-col gap-1">
  {sections.map((section, index) => (
    <a
      href={`#${section.id}`}
      data-section-index={index}
      class="side-menu-item block px-3 py-2 text-sm rounded-lg border-l-2 border-transparent
        text-gray-600 dark:text-gray-400
        hover:bg-gray-50 dark:hover:bg-gray-800/50
        hover:text-gray-900 dark:hover:text-gray-200
        transition-all duration-200"
    >
      {section.title}
    </a>
  ))}
</nav>

<script>
const items = document.querySelectorAll(".side-menu-item");

const observer = new IntersectionObserver(
  (entries) => {
    const visible = entries
      .filter((e) => e.isIntersecting)
      .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

    if (visible.length === 0) return;

    const activeId = visible[0].target.id;

    items.forEach((item) => {
      const href = item.getAttribute("href");
      if (href === `#${activeId}`) {
        item.classList.add(
          "bg-blue-50",
          "dark:bg-blue-950/30",
          "text-blue-600",
          "dark:text-blue-400",
          "font-medium",
          "border-blue-600",
          "dark:border-blue-400"
        );
        item.classList.remove(
          "border-transparent",
          "text-gray-600",
          "dark:text-gray-400"
        );
      } else {
        item.classList.remove(
          "bg-blue-50",
          "dark:bg-blue-950/30",
          "text-blue-600",
          "dark:text-blue-400",
          "font-medium",
          "border-blue-600",
          "dark:border-blue-400"
        );
        item.classList.add("border-transparent", "text-gray-600", "dark:text-gray-400");
      }
    });
  },
  {
    rootMargin: "-80px 0px -50% 0px",
    threshold: 0,
  }
);

items.forEach((item) => {
  const href = item.getAttribute("href");
  if (href) {
    const id = href.replace("#", "");
    const section = document.getElementById(id);
    if (section) observer.observe(section);
  }
});

items.forEach((item) => {
  item.addEventListener("click", (e) => {
    e.preventDefault();
    const href = item.getAttribute("href");
    if (href) {
      const target = document.querySelector(href);
      if (target) {
        target.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    }
  });
});
</script>
