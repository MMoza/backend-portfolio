---
const { id, title, text, image, imageAlt } = Astro.props;
---

<section id={id} class="scroll-mt-28 mb-16">
  <h2 class="text-2xl font-bold mb-6 text-gray-900 dark:text-gray-100">
    {title}
  </h2>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
    <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
      {text}
    </p>

    <img
      src={image}
      alt={imageAlt}
      class="rounded-lg shadow-md hover:shadow-lg transition-shadow duration-300 w-full"
      loading="lazy"
    />
  </div>
</section>
