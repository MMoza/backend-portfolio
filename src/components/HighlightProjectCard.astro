---
const { project } = Astro.props;
---

<a
  href={`/experience/projects/${project.slug}`}
  class="block"
>

<article
  class="group border border-gray-200 dark:border-gray-800 rounded-xl p-6 transition-all duration-300 hover:shadow-md hover:-translate-y-1 bg-white dark:bg-gray-900 cursor-pointer flex flex-col h-full"
>

  <!-- Title -->

  <h3 class="text-lg font-semibold mb-2 group-hover:text-blue-600 transition-colors">
    {project.title}
  </h3>

  <!-- Description -->

  <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
    {project.description}
  </p>

  <!-- Tags -->

  <div class="flex flex-wrap gap-2 mt-auto">

    {project.tags.map((tag) => (
      <span class="text-xs px-2 py-1 rounded-md bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300">
        {tag}
      </span>
    ))}

  </div>

</article>

</a>