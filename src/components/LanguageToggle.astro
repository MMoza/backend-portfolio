---
import { getLangFromUrl } from "../i18n/getLang";

const lang = getLangFromUrl(Astro.url);

const currentPath = Astro.url.pathname;
const pathWithoutLang = currentPath.replace(/^\/es/, "") || "/";
---

<div
  class="relative flex items-center text-xs font-medium rounded-lg border border-gray-200 dark:border-gray-800 overflow-hidden bg-gray-50 dark:bg-gray-900 shadow-sm w-fit"
>

  <!-- Slider -->
  <span
    class={`absolute top-0 bottom-0 w-1/2 bg-blue-600 transition-transform duration-300 ease-in-out ${
      lang === "es" ? "translate-x-full" : "translate-x-0"
    }`}
  ></span>

  <a
    href={pathWithoutLang}
    class={`relative px-3 py-1.5 z-10 transition-colors duration-300 ${
      lang === "en"
        ? "text-white"
        : "text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200"
    }`}
  >
    EN
  </a>

  <a
    href={`/es${pathWithoutLang}`}
    class={`relative px-3 py-1.5 z-10 transition-colors duration-300 ${
      lang === "es"
        ? "text-white"
        : "text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200"
    }`}
  >
    ES
  </a>

</div>