---
const { value, label } = Astro.props;
---

<div class="border border-gray-200 dark:border-gray-800 rounded-lg p-5 bg-white dark:bg-gray-900 text-center transition hover:shadow-sm">

  <p class="text-2xl font-semibold text-blue-600">
    {value}
  </p>

  <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
    {label}
  </p>

</div>