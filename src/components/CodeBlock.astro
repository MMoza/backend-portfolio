---
const { id, title, files } = Astro.props;
---

<section id={id} class="scroll-mt-28 mb-16">
  <h2 class="text-2xl font-bold mb-6 text-gray-900 dark:text-gray-100">
    {title}
  </h2>

  <div class="rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
    <!-- Tabs -->
    <div class="flex gap-1 border-b border-gray-200 dark:border-gray-700 bg-gray-100/50 dark:bg-gray-800/50 px-2 pt-2">
      {files.map((file, index) => (
        <button
          data-tab-index={index}
          class={`code-tab px-4 py-2 text-sm rounded-t-lg border transition-colors duration-200
            ${index === 0
              ? "bg-white dark:bg-gray-900 border-gray-200 dark:border-gray-700 border-b-white dark:border-b-gray-900 text-gray-900 dark:text-gray-100 font-medium"
              : "border-transparent text-gray-500 hover:text-gray-700 dark:hover:text-gray-300"
            }`}
        >
          {file.name}
        </button>
      ))}
    </div>

    <!-- Code panels -->
    <div class="relative">
      {files.map((file, index) => (
        <div
          data-code-panel={index}
          class={`code-panel ${index === 0 ? "block" : "hidden"}`}
        >
          <!-- Light theme version -->
          <div
            class="p-4 overflow-x-auto bg-white dark:hidden"
            set:html={file.highlightedLight}
          />
          <!-- Dark theme version -->
          <div
            class="p-4 overflow-x-auto bg-gray-950 hidden dark:block"
            set:html={file.highlightedDark}
          />
        </div>
      ))}
    </div>
  </div>
</section>

<script>
const tabs = document.querySelectorAll(".code-tab");
const panels = document.querySelectorAll(".code-panel");

tabs.forEach((tab) => {
  tab.addEventListener("click", () => {
    const index = tab.dataset.tabIndex;

    tabs.forEach((t) => {
      t.classList.remove(
        "bg-white",
        "dark:bg-gray-900",
        "border-gray-200",
        "dark:border-gray-700",
        "border-b-white",
        "dark:border-b-gray-900",
        "text-gray-900",
        "dark:text-gray-100",
        "font-medium"
      );
      t.classList.add("border-transparent", "text-gray-500");
    });

    tab.classList.remove("border-transparent", "text-gray-500");
    tab.classList.add(
      "bg-white",
      "dark:bg-gray-900",
      "border-gray-200",
      "dark:border-gray-700",
      "border-b-white",
      "dark:border-b-gray-900",
      "text-gray-900",
      "dark:text-gray-100",
      "font-medium"
    );

    panels.forEach((panel) => {
      if (panel.dataset.codePanel === index) {
        panel.classList.remove("hidden");
        panel.classList.add("block");
      } else {
        panel.classList.remove("block");
        panel.classList.add("hidden");
      }
    });
  });
});
</script>
