---
const { project } = Astro.props;
---

<style>
  .project-title {
    transition: all 0.3s ease;
  }

  .group:hover .project-title {
    background: linear-gradient(90deg, black, rgb(59, 130, 246), black);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: shineTitle 0.8s ease forwards;
  }

  @media (prefers-color-scheme: dark) {
    .group:hover .project-title {
      background: linear-gradient(90deg, rgb(174, 174, 174), rgb(59, 130, 246), rgb(174, 174, 174));
      background-size: 200% 100%;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: shineTitle 0.8s ease forwards;
    }
  }

  @keyframes shineTitle {
    0% {
      background-position: 200% center;
    }
    100% {
      background-position: 0% center;
    }
  }
</style>

<article
  class="relative group border border-gray-200 dark:border-gray-800 rounded-xl p-6 transition-all duration-300 hover:shadow-md hover:-translate-y-1 bg-white dark:bg-gray-900 cursor-pointer flex flex-col h-full overflow-hidden"
>
  <!-- Borde superior degradado -->
  <div class="absolute top-0 inset-x-0 h-[1px] bg-gradient-to-r from-transparent via-blue-500/60 to-transparent transition-opacity duration-300 group-hover:opacity-100 opacity-50 z-20"></div>

  <!-- Borde inferior degradado -->
  <div class="absolute bottom-0 inset-x-0 h-[1px] bg-gradient-to-r from-transparent via-blue-500/60 to-transparent transition-opacity duration-300 group-hover:opacity-100 opacity-50 z-20"></div>

  <!-- Borde izquierdo degradado -->
  <div class="absolute left-0 inset-y-0 w-[1px] bg-gradient-to-b from-transparent via-blue-500/60 to-transparent transition-opacity duration-300 group-hover:opacity-100 opacity-50 z-20"></div>

  <!-- Borde derecho degradado -->
  <div class="absolute right-0 inset-y-0 w-[1px] bg-gradient-to-b from-transparent via-blue-500/60 to-transparent transition-opacity duration-300 group-hover:opacity-100 opacity-50 z-20"></div>

  <!-- Image -->
  {project.image && (
    <img
      src={project.image}
      alt={project.title}
      class="absolute top-0 left-0 right-0 w-full h-50 object-cover rounded-t-lg transition-transform duration-300 group-hover:scale-105 origin-top z-0"
    />
  )}

  <!-- Image spacing -->
  <div class="h-50 -mx-6 -mt-6 mb-4"></div>

  <!-- Overlay link -->
  <a
    href={`/projects/${project.slug}`}
    class="absolute inset-0 z-10"
    aria-label={project.title}
  ></a>

  <span class="text-xs text-gray-500">
    {project.date}
  </span>

  <h2 class="text-lg font-semibold mt-2 mb-3 project-title">
    {project.title}
  </h2>

  <p class="text-sm text-gray-600 dark:text-gray-400 mb-4 min-h-15">
    {project.description}
  </p>

  <div class="mt-auto flex items-end justify-between gap-4">

    <div class="flex flex-wrap gap-2">
      {project.tech.map((tech) => (
        <span class="text-xs px-2 py-1 rounded-md bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300">
          {tech}
        </span>
      ))}
    </div>

    <!-- GitHub -->
    <a
      href={project.github}
      target="_blank"
      rel="noopener noreferrer"
      class="relative z-20 text-gray-400 hover:text-blue-600 hover:scale-110 transition-all duration-200"
    >
          <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="w-5 h-5"
        >
        <path d="M12 0C5.37 0 0 5.37 0 12a12 12 0 008.21 11.38c.6.11.82-.26.82-.58v-2.02c-3.34.73-4.04-1.61-4.04-1.61-.55-1.38-1.33-1.75-1.33-1.75-1.09-.75.08-.74.08-.74 1.2.08 1.84 1.23 1.84 1.23 1.07 1.84 2.8 1.31 3.48 1 .11-.77.42-1.31.76-1.61-2.66-.3-5.46-1.33-5.46-5.93 0-1.31.47-2.38 1.23-3.22-.12-.3-.53-1.52.12-3.18 0 0 1-.32 3.3 1.23a11.4 11.4 0 016 0C17.3 3.6 18.3 3.92 18.3 3.92c.65 1.66.24 2.88.12 3.18.76.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.62-5.47 5.92.43.37.82 1.1.82 2.22v3.29c0 .32.21.7.83.58A12 12 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
    </a>

  </div>

</article>