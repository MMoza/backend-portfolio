---
const { experience } = Astro.props;
---

<style>
  .experience-title {
    transition: all 0.3s ease;
  }

  .group:hover .experience-title {
    background: linear-gradient(90deg, black, rgb(59, 130, 246), black);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: shineTitle 0.8s ease forwards;
  }

  @media (prefers-color-scheme: dark) {
    .group:hover .experience-title {
      background: linear-gradient(90deg, rgb(174, 174, 174), rgb(59, 130, 246), rgb(174, 174, 174));
      background-size: 200% 100%;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: shineTitle 0.8s ease forwards;
    }
  }

  @keyframes shineTitle {
    0% {
      background-position: 200% center;
    }
    100% {
      background-position: 0% center;
    }
  }
</style>

<article
  class="relative group border border-gray-200 dark:border-gray-800 rounded-xl p-6 md:p-8 bg-white dark:bg-gray-900 transition-all duration-300 hover:shadow-md hover:-translate-y-1 flex flex-col h-full overflow-hidden"
>

  <!-- Borde superior degradado -->
  <div class="absolute top-0 inset-x-0 h-[1px] bg-gradient-to-r from-transparent via-blue-500/60 to-transparent transition-opacity duration-300 group-hover:opacity-100 opacity-50"></div>

  <!-- Borde inferior degradado -->
  <div class="absolute bottom-0 inset-x-0 h-[1px] bg-gradient-to-r from-transparent via-blue-500/60 to-transparent transition-opacity duration-300 group-hover:opacity-100 opacity-50"></div>

  <!-- Borde izquierdo degradado -->
  <div class="absolute left-0 inset-y-0 w-[1px] bg-gradient-to-b from-transparent via-blue-500/60 to-transparent transition-opacity duration-300 group-hover:opacity-100 opacity-50"></div>

  <!-- Borde derecho degradado -->
  <div class="absolute right-0 inset-y-0 w-[1px] bg-gradient-to-b from-transparent via-blue-500/60 to-transparent transition-opacity duration-300 group-hover:opacity-100 opacity-50"></div>

  <!-- Overlay link -->
  <a
    href={`/experience/${experience.slug}`}
    class="absolute inset-0 z-10"
    aria-label={experience.title}
  ></a>

  <span class="text-xs text-gray-500">
    {experience.date}
  </span>

  <h2 class="experience-title text-lg md:text-xl font-semibold mt-2 mb-3 transition-colors">
    {experience.title}
  </h2>

  <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
    {experience.description}
  </p>

  <!-- Key points -->
  {experience.points && (
    <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-1 mb-4">
      {experience.points.map((point) => (
        <li>• {point}</li>
      ))}
    </ul>
  )}

  <!-- Skills -->
  {experience.skills && (
    <div class="mt-auto flex flex-wrap gap-2">

      {experience.skills.map((skill) => (
        <span class="text-xs px-2 py-1 rounded-md bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300">
          {skill}
        </span>
      ))}

    </div>
  )}

</article>