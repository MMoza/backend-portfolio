---
const { experience } = Astro.props;
---

<article
  class="relative group border border-gray-200 dark:border-gray-800 rounded-xl p-6 md:p-8 bg-white dark:bg-gray-900 transition-all duration-300 hover:shadow-md hover:-translate-y-1 flex flex-col h-full"
>

  <!-- Overlay link -->
  <a
    href={`/experience/${experience.slug}`}
    class="absolute inset-0 z-10"
    aria-label={experience.title}
  ></a>

  <span class="text-xs text-gray-500">
    {experience.date}
  </span>

  <h2 class="text-lg md:text-xl font-semibold mt-2 mb-3 group-hover:text-blue-600 transition-colors">
    {experience.title}
  </h2>

  <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
    {experience.description}
  </p>

  <!-- Key points -->
  {experience.points && (
    <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-1 mb-4">
      {experience.points.map((point) => (
        <li>• {point}</li>
      ))}
    </ul>
  )}

  <!-- Skills -->
  {experience.skills && (
    <div class="mt-auto flex flex-wrap gap-2">

      {experience.skills.map((skill) => (
        <span class="text-xs px-2 py-1 rounded-md bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300">
          {skill}
        </span>
      ))}

    </div>
  )}

</article>